rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // ──────────────────────────────────────────────────────────
    // Helper: Check if userA has blocked userB
    // Returns true if /users/{userA}/blockedUsers/{userB} exists
    // ──────────────────────────────────────────────────────────
    function isBlocked(userA, userB) {
      return exists(/databases/$(database)/documents/users/$(userA)/blockedUsers/$(userB));
    }

    function isInteractionAllowed(userA, userB) {
      return !isBlocked(userA, userB) && !isBlocked(userB, userA);
    }

    // Helper: determine the other participant in a chat and check no block exists in either direction.
    // For group chats (isGroup == true), block checks are skipped — group membership and admin
    // policies handle access control instead.
    function isMessageWriteAllowed(chatId) {
      let chat = get(/databases/$(database)/documents/chats/$(chatId)).data;
      let isGroup = chat.get('isGroup', false);
      let otherUser = isGroup ? '' :
        (chat.participants[0] == request.auth.uid ? chat.participants[1] : chat.participants[0]);
      return isGroup || isInteractionAllowed(request.auth.uid, otherUser);
    }

    function isTerminalCallStatus(status) {
      return status in ['ended', 'declined', 'missed', 'no_answer', 'busy'];
    }

    function isBlockedCallTerminationUpdate() {
      return isTerminalCallStatus(request.resource.data.status)
        && request.resource.data.callerId == resource.data.callerId
        && request.resource.data.receiverId == resource.data.receiverId
        && request.resource.data.diff(resource.data).changedKeys().hasOnly(['status', 'endedAt']);
    }

    // ──────────────────────────────────────────────────────────
    // Health Check
    // ──────────────────────────────────────────────────────────
    match /_health_check_/{document} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // ──────────────────────────────────────────────────────────
    // Admin records (portal-managed via the Admin SDK)
    // The Glyph Admin portal accesses admins/{uid} EXCLUSIVELY through the
    // Firebase Admin SDK, which bypasses these rules. The Android client gates
    // admin capability on the `admin` custom claim (context.auth.token.admin),
    // NOT this document, so it never reads admins/{uid}. As defense-in-depth:
    //  - writes from clients are DENIED (admin changes happen server-side only);
    //  - reads are allowed only to authenticated admins (token.admin == true).
    // ──────────────────────────────────────────────────────────
    match /admins/{uid} {
      allow read: if request.auth != null && request.auth.token.admin == true;
      allow write: if false;
    }

    // ──────────────────────────────────────────────────────────
    // User Profiles
    // get  (single doc): any authenticated user UNLESS the profile owner blocked the reader
    // list (collection query): any authenticated user — Firestore cannot evaluate per-document
    //      exists() calls upfront for unfiltered collection queries, so keeping the block
    //      check here rejects the entire query with PERMISSION_DENIED. Block filtering is
    //      enforced at the chat/message layer where it matters most.
    // Write: only the owner
    // ──────────────────────────────────────────────────────────
    match /users/{userId} {
      allow get: if request.auth != null
                 && !isBlocked(userId, request.auth.uid);
      allow list: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == userId;

      // ── Block sub-collections ──
      // blockedUsers: users I have blocked
      //   - Only owner can read/write their own block list
      //   - Cloud Functions also need to read blockedBy; they use Admin SDK (bypasses rules)
      match /blockedUsers/{blockedId} {
        allow read: if request.auth != null && request.auth.uid == userId;
        allow write: if request.auth != null && request.auth.uid == userId;
      }

      // blockedBy: users who blocked me
      //   - Only owner can read their own blockedBy list
      //   - Write is allowed by the blocker (any authenticated user can add themselves)
      //     but only for their own UID entry, and only with a valid blockedAt field
      match /blockedBy/{blockerId} {
        allow read: if request.auth != null && request.auth.uid == userId;
        allow create: if request.auth != null 
                      && request.auth.uid == blockerId
                      && request.resource.data.keys().hasAll(['blockedAt']);
        allow delete: if request.auth != null && request.auth.uid == blockerId;
        allow update: if false;
      }

      // ── User Settings (privacy, notifications, etc.) ──
      // Only the owner can read/write their own settings.
      // Other authenticated users can read (to check visibility preferences)
      // as long as they are not blocked.
      match /settings/{document} {
        allow read: if request.auth != null
                    && (request.auth.uid == userId
                        || (!isBlocked(userId, request.auth.uid)
                            && !isBlocked(request.auth.uid, userId)));
        allow write: if request.auth != null
                     && request.auth.uid == userId;
      }

      // ── Live Audio Sharing config ──
      // Owner can read/write their own config.
      // Other authenticated users can read (to check shareMic / audience)
      // as long as they are not blocked.
      match /liveAudio/{document} {
        allow read: if request.auth != null
                    && !isBlocked(userId, request.auth.uid)
                    && !isBlocked(request.auth.uid, userId);
        allow write: if request.auth != null
                     && request.auth.uid == userId;
      }

      // ── Hidden Chats (deleted group chats the user has dismissed) ──
      // Only the owner can read/write their own hidden chat records.
      match /hidden_chats/{chatId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
    }

    // ──────────────────────────────────────────────────────────
    // Chat Documents
    // ──────────────────────────────────────────────────────────
    match /chats/{chatId} {
      // Read: any participant (block check skipped — chat itself doesn't reveal sensitive
      // content, and group chats may include users with no pairwise block relationship).
      allow read: if request.auth != null 
                  && request.auth.uid in resource.data.participants;
      
      // Update:
      //   * 1:1 → participant AND no block in either direction (existing behavior)
      //   * group → participant; admin-only fields require admin membership
      allow update: if request.auth != null 
                    && request.auth.uid in resource.data.participants
                    && (
                         (
                           !resource.data.get('isGroup', false)
                           && !isBlocked(
                                resource.data.participants[0] == request.auth.uid 
                                  ? resource.data.participants[1] 
                                  : resource.data.participants[0],
                                request.auth.uid
                              )
                           && !isBlocked(
                                request.auth.uid,
                                resource.data.participants[0] == request.auth.uid 
                                  ? resource.data.participants[1] 
                                  : resource.data.participants[0]
                              )
                         )
                         ||
                         (
                           resource.data.get('isGroup', false)
                           && (
                                !request.resource.data.diff(resource.data).affectedKeys()
                                  .hasAny(['groupName','groupIconUrl','participants','admins','isGroup','createdBy','createdAt'])
                                || request.auth.uid in resource.data.admins
                              )
                         )
                       );
      
      // Create: user is participant. For groups: caller must also be in admins
      // and createdBy must equal the caller's uid.
      allow create: if request.auth != null 
                    && request.auth.uid in request.resource.data.participants
                    && (
                         !request.resource.data.get('isGroup', false)
                         || (
                              request.auth.uid in request.resource.data.get('admins', [])
                              && request.resource.data.get('createdBy', '') == request.auth.uid
                            )
                       );

      // Message Sub-collection
      match /messages/{messageId} {
        // Read: participant of the chat
        allow read: if request.auth != null && 
          request.auth.uid in get(/databases/$(database)/documents/chats/$(chatId)).data.participants;
        
        // Create: participant of the chat AND no block in either direction (1:1 only;
        // isMessageWriteAllowed short-circuits to true for groups). Phase 9: also
        // require the new message to carry senderId == auth.uid so a participant
        // cannot spoof messages claiming to come from another member of the chat.
        allow create: if request.auth != null
          && request.auth.uid in get(/databases/$(database)/documents/chats/$(chatId)).data.participants
          && isMessageWriteAllowed(chatId)
          && request.resource.data.get('senderId', '') == request.auth.uid;

        // Update / delete: participant + block-aware (legacy behaviour). The Cloud
        // Function uses Admin SDK to bypass these rules, so server-side status /
        // delivery timestamp writes continue to work.
        allow update, delete: if request.auth != null && 
          request.auth.uid in get(/databases/$(database)/documents/chats/$(chatId)).data.participants
          && isMessageWriteAllowed(chatId);

        // Group-only delivery/read receipts: any group participant may append their
        // own uid to deliveredTo / readBy (and only those two fields).
        allow update: if request.auth != null
          && get(/databases/$(database)/documents/chats/$(chatId)).data.get('isGroup', false)
          && request.auth.uid in get(/databases/$(database)/documents/chats/$(chatId)).data.participants
          && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['deliveredTo', 'readBy'])
          && (
               request.auth.uid in request.resource.data.get('deliveredTo', [])
               || request.auth.uid in request.resource.data.get('readBy', [])
             );
      }
    }
    
    // ──────────────────────────────────────────────────────────
    // Calls
    // callerId or receiverId can read/update; only caller creates
    // ──────────────────────────────────────────────────────────
    match /calls/{callId} {
      allow read: if request.auth != null
                  && (request.auth.uid == resource.data.callerId
                      || request.auth.uid == resource.data.receiverId);
      allow create: if request.auth != null
                    && request.auth.uid == request.resource.data.callerId
                    && isInteractionAllowed(
                         request.resource.data.callerId,
                         request.resource.data.receiverId
                       );
      allow update: if request.auth != null
                    && (request.auth.uid == resource.data.callerId
                        || request.auth.uid == resource.data.receiverId)
                    && (
                         isInteractionAllowed(resource.data.callerId, resource.data.receiverId)
                         || isBlockedCallTerminationUpdate()
                       );
      allow delete: if request.auth != null
                    && (request.auth.uid == resource.data.callerId
                        || request.auth.uid == resource.data.receiverId);

      // ICE candidates – writable by either participant
      match /candidates/{candidateId} {
        allow read: if request.auth != null
                    && (request.auth.uid == get(/databases/$(database)/documents/calls/$(callId)).data.callerId
                        || request.auth.uid == get(/databases/$(database)/documents/calls/$(callId)).data.receiverId);
        allow create: if request.auth != null
                      && (request.auth.uid == get(/databases/$(database)/documents/calls/$(callId)).data.callerId
                          || request.auth.uid == get(/databases/$(database)/documents/calls/$(callId)).data.receiverId)
                      && isInteractionAllowed(
                           get(/databases/$(database)/documents/calls/$(callId)).data.callerId,
                           get(/databases/$(database)/documents/calls/$(callId)).data.receiverId
                         );
        allow update: if false;
        allow delete: if request.auth != null
                      && (request.auth.uid == get(/databases/$(database)/documents/calls/$(callId)).data.callerId
                          || request.auth.uid == get(/databases/$(database)/documents/calls/$(callId)).data.receiverId);
      }
    }

    match /walkieTalkieRequests/{sessionId} {
      allow read: if request.auth != null
                  && (request.auth.uid == resource.data.initiatorId
                      || request.auth.uid == resource.data.responderId);
      allow create: if request.auth != null
                    && request.auth.uid == request.resource.data.initiatorId
                    && isInteractionAllowed(
                         request.resource.data.initiatorId,
                         request.resource.data.responderId
                       );
      allow update: if request.auth != null
                    && (request.auth.uid == resource.data.initiatorId
                        || request.auth.uid == resource.data.responderId);
      allow delete: if request.auth != null
                    && (request.auth.uid == resource.data.initiatorId
                        || request.auth.uid == resource.data.responderId);

      match /candidates/{candidateId} {
        allow read: if request.auth != null
                    && (request.auth.uid == get(/databases/$(database)/documents/walkieTalkieRequests/$(sessionId)).data.initiatorId
                        || request.auth.uid == get(/databases/$(database)/documents/walkieTalkieRequests/$(sessionId)).data.responderId);
        allow create: if request.auth != null
                      && (request.auth.uid == get(/databases/$(database)/documents/walkieTalkieRequests/$(sessionId)).data.initiatorId
                          || request.auth.uid == get(/databases/$(database)/documents/walkieTalkieRequests/$(sessionId)).data.responderId);
        allow update, delete: if false;
      }
    }

    // ──────────────────────────────────────────────────────────
    // Group Calls
    // creatorId can create; any authenticated participant can read/update
    // Participants are stored at groupCalls/{id}/participants/{userId}
    // ──────────────────────────────────────────────────────────
    match /groupCalls/{groupCallId} {
      // Any authenticated user can read (they need to check if invited)
      allow read: if request.auth != null;
      // Only the creator can create
      allow create: if request.auth != null
                    && request.resource.data.creatorId == request.auth.uid;
      // Any authenticated user can update (participants mark status, end call)
      allow update: if request.auth != null;
      allow delete: if request.auth != null
                    && resource.data.creatorId == request.auth.uid;

      // Participants sub-collection
      match /participants/{userId} {
        allow read: if request.auth != null;
        // A user can create/update their own participant doc, or the creator can add them
        allow create: if request.auth != null;
        allow update: if request.auth != null;
        allow delete: if request.auth != null
                      && (request.auth.uid == userId
                          || request.auth.uid == get(/databases/$(database)/documents/groupCalls/$(groupCallId)).data.creatorId);
      }

      // Signaling sub-collection (offer/answer per pair)
      match /signaling/{pairKey} {
        allow read, write: if request.auth != null;

        // ICE candidates
        match /candidates/{candidateId} {
          allow read, write: if request.auth != null;
        }
      }
    }

    // Group call invitations (written by caller, read by Cloud Function)
    match /groupCallInvitations/{invitationId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null;
      allow update, delete: if false;
    }

    // ──────────────────────────────────────────────────────────
    // Statuses (WhatsApp-style 24h stories)
    // ──────────────────────────────────────────────────────────
    match /statuses/{statusId} {
      // Get (single doc): owner OR in visibleTo, AND not blocked (exists() safe for get)
      allow get: if request.auth != null
                 && (
                      request.auth.uid == resource.data.userId
                      || request.auth.uid in resource.data.visibleTo
                    )
                 && !isBlocked(resource.data.userId, request.auth.uid)
                 && !isBlocked(request.auth.uid, resource.data.userId);

      // List (collection query): owner OR in visibleTo.
      // No exists()/isBlocked here — Firestore cannot evaluate per-document
      // exists() calls for collection queries and would reject the whole query.
      // Block enforcement is handled at write time (visibleTo excludes blocked
      // users) and client-side as a defensive filter.
      allow list: if request.auth != null
                  && (
                       resource.data.userId == request.auth.uid
                       || request.auth.uid in resource.data.visibleTo
                     );

      // Create: only the owner (userId must match auth uid) and must include visibleTo
      allow create: if request.auth != null
                    && request.resource.data.userId == request.auth.uid
                    && request.resource.data.keys().hasAll(['visibleTo'])
                    && request.auth.uid in request.resource.data.visibleTo;

      // Update: owner can update any field.
      // Non-owners may only append their own uid to viewerIds or likedByIds,
      // and only if they are not blocked in either direction.
       allow update: if request.auth != null
            && (
              request.auth.uid == resource.data.userId
              || (
                              !isBlocked(resource.data.userId, request.auth.uid)
                              && !isBlocked(request.auth.uid, resource.data.userId)
                              && (
                                   request.resource.data.diff(resource.data).changedKeys().hasOnly(['viewerIds'])
                                   && request.auth.uid in request.resource.data.viewerIds
                                   && !(request.auth.uid in resource.data.viewerIds)
                                   && request.resource.data.viewerIds.size() == resource.data.viewerIds.size() + 1
                                 ||
                                   request.resource.data.diff(resource.data).changedKeys().hasOnly(['likedByIds'])
                                   && request.auth.uid in request.resource.data.likedByIds
                                   && !(request.auth.uid in resource.data.likedByIds)
                                   && request.resource.data.likedByIds.size() == resource.data.likedByIds.size() + 1
                                 )
                 )
               );

      // Delete: only the owner
      allow delete: if request.auth != null
                    && resource.data.userId == request.auth.uid;
    }

    // ──────────────────────────────────────────────────────────
    // Status Notification Subscriptions
    // A subscriber can create/delete their own entry under the publisher's doc.
    // Cloud Function reads via Admin SDK (bypasses rules).
    // ──────────────────────────────────────────────────────────
    match /statusNotifSubscriptions/{publisherUserId}/subscribers/{subscriberId} {
      allow read, write: if request.auth != null && request.auth.uid == subscriberId;
    }

    // ──────────────────────────────────────────────────────────
    // Official Messages (portal-published, company broadcasts)
    // Written by the Glyph Admin portal via the Admin SDK (bypasses rules),
    // so client writes are DENIED. Any authenticated user may READ — the
    // Android app observes official_messages/{id} for the official inbox.
    // ──────────────────────────────────────────────────────────
    match /official_messages/{id} {
      allow read: if request.auth != null;
      allow write: if false;
    }

    // ──────────────────────────────────────────────────────────
    // Official Status (portal-published, company stories)
    // Written by the Glyph Admin portal via the Admin SDK (bypasses rules),
    // so client writes are DENIED. Any authenticated user may READ — the
    // Android app renders official_status/{id} in the Status UI.
    // ──────────────────────────────────────────────────────────
    match /official_status/{id} {
      allow read: if request.auth != null;
      allow write: if false;
    }

    // ──────────────────────────────────────────────────────────
    // Default: deny all
    // ──────────────────────────────────────────────────────────
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
