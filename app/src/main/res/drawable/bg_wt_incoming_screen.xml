<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape android:shape="rectangle">
            <gradient
                android:angle="270"
                android:endColor="#081C25"
                android:startColor="#031018" />
        </shape>
    </item>
    <item android:left="-80dp" android:top="-40dp" android:right="120dp" android:bottom="520dp">
        <shape android:shape="oval">
            <gradient
                android:centerColor="#3357D4C1"
                android:endColor="#0057D4C1"
                android:startColor="#6657D4C1"
                android:type="radial"
                android:gradientRadius="240dp" />
        </shape>
    </item>
    <item android:left="140dp" android:top="360dp" android:right="-70dp" android:bottom="-40dp">
        <shape android:shape="oval">
            <gradient
                android:centerColor="#224B74FF"
                android:endColor="#004B74FF"
                android:startColor="#664B74FF"
                android:type="radial"
                android:gradientRadius="260dp" />
        </shape>
    </item>
</layer-list>