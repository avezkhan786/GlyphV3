<?xml version="1.0" encoding="utf-8"?>
<!-- Theme-aware chat input background with subtle border -->
<shape xmlns:android="http://schemas.android.com/apk/res/android"
    android:shape="rectangle">
    <!-- Match AppBar/header background exactly -->
    <solid android:color="?attr/glyphChatInputBackground" />
    <!-- Very subtle border using surface variant for minimal contrast -->
    <stroke
        android:width="1dp"
        android:color="?attr/colorSurfaceVariant" />
    <corners android:radius="24dp" />
</shape>
