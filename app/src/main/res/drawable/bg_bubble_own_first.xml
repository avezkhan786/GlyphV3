<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Bubble Body  (inset right side) -->
    <item
        android:right="8dp">
        <shape android:shape="rectangle">
            <solid android:color="?attr/glyphBubbleOwn" />
            <stroke
              android:width="1.5dp"
              android:color="?attr/glyphDivider" />
            <corners
                android:topLeftRadius="12dp"
                android:topRightRadius="0dp"
                android:bottomLeftRadius="12dp"
                android:bottomRightRadius="12dp" />
        </shape>
    </item>

    <!-- Tail (Vector) -->
    <item
        android:drawable="@drawable/ic_tail_outgoing"
        android:width="15dp"
        android:height="15dp"
        android:gravity="top|right"
        android:top="0dp"
        android:right="0dp" />

</layer-list>