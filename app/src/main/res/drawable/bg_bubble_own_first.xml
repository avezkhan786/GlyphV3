<?xml version="1.0" encoding="utf-8"?>
<!-- Premium own first bubble with tail — refined stroke, polished corners -->
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Bubble Body (inset right side for tail) -->
    <item android:right="8dp">
        <shape android:shape="rectangle">
            <solid android:color="?attr/glyphBubbleOwn" />
            <stroke
                android:width="1dp"
                android:color="#18000000" />
            <corners
                android:topLeftRadius="16dp"
                android:topRightRadius="0dp"
                android:bottomLeftRadius="16dp"
                android:bottomRightRadius="16dp" />
        </shape>
    </item>
    <!-- Tail — positioned at top right -->
    <item
        android:drawable="@drawable/ic_tail_outgoing"
        android:width="15dp"
        android:height="15dp"
        android:gravity="top|right"
        android:top="0dp"
        android:right="0dp" />
</layer-list>
