<?xml version="1.0" encoding="utf-8"?>
<!-- Premium pastel incoming bubble — gradient fill, refined border -->
<shape xmlns:android="http://schemas.android.com/apk/res/android"
    android:shape="rectangle">
    <gradient
        android:type="linear"
        android:angle="0"
        android:startColor="@color/pastel_bubble_incoming_start"
        android:endColor="@color/pastel_bubble_incoming_end" />
    <stroke
        android:width="0.5dp"
        android:color="@color/pastel_bubble_incoming_border" />
    <corners android:radius="22dp" />
</shape>
