<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="56dp"
    android:layout_height="56dp"
    android:layout_marginEnd="4dp">

    <!-- Thumbnail image -->
    <ImageView
        android:id="@+id/ivThumbnail"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:scaleType="centerCrop"
        tools:src="@tools:sample/backgrounds/scenic" />

    <!-- Play icon for videos -->
    <ImageView
        android:id="@+id/ivPlayIcon"
        android:layout_width="20dp"
        android:layout_height="20dp"
        android:layout_gravity="center"
        android:src="@drawable/ic_play_circle"
        android:visibility="gone"
        tools:visibility="visible" />

    <!-- Selection border -->
    <View
        android:id="@+id/selectionBorder"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@drawable/bg_thumbnail_selected"
        android:visibility="gone"
        tools:visibility="visible" />

    <View
        android:id="@+id/selectedScrim"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#66000000"
        android:visibility="gone" />

    <ImageView
        android:id="@+id/selectedCheck"
        android:layout_width="22dp"
        android:layout_height="22dp"
        android:layout_gravity="top|end"
        android:layout_margin="4dp"
        android:background="@drawable/bg_share_selection_check"
        android:padding="5dp"
        android:src="@drawable/ic_check"
        android:tint="@android:color/white"
        android:visibility="gone" />

</FrameLayout>
