<?xml version="1.0" encoding="utf-8"?>
<!--
    Group-only sender attribution shown above incoming bubbles.
    Hidden by default; ChatAdapter toggles visibility for group chats.
-->
<TextView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/tvGroupSenderName"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:layout_marginStart="12dp"
    android:layout_marginTop="6dp"
    android:layout_marginEnd="12dp"
    android:layout_marginBottom="2dp"
    android:ellipsize="end"
    android:maxLines="1"
    android:textColor="?attr/glyphAccent"
    android:textSize="12sp"
    android:textStyle="bold"
    android:visibility="gone"
    tools:text="Alex Johnson"
    tools:visibility="visible" />
