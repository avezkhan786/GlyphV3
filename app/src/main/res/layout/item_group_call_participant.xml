<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/participantRoot"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FF2A2A2A"
    android:layout_margin="2dp"
    android:clipChildren="true"
    android:clipToPadding="true">

    <!-- Remote video (or local self-view) -->
    <org.webrtc.SurfaceViewRenderer
        android:id="@+id/participantVideoView"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:visibility="gone" />

    <!-- Avatar placeholder when video is off -->
    <LinearLayout
        android:id="@+id/participantAvatarContainer"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:gravity="center"
        android:orientation="vertical"
        android:visibility="visible">

        <ImageView
            android:id="@+id/ivParticipantAvatar"
            android:layout_width="80dp"
            android:layout_height="80dp"
            android:background="@drawable/bg_call_avatar"
            android:clipToOutline="true"
            android:contentDescription="@null"
            android:scaleType="centerCrop"
            android:src="@drawable/ic_default_avatar" />

        <TextView
            android:id="@+id/tvParticipantNameCenter"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:textColor="#FFFFFFFF"
            android:textSize="14sp"
            android:textStyle="bold"
            android:gravity="center"
            tools:text="John" />
    </LinearLayout>

    <!-- Bottom overlay: name + indicators -->
    <LinearLayout
        android:id="@+id/participantBottomOverlay"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:background="#66000000"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingHorizontal="8dp"
        android:paddingVertical="6dp">

        <TextView
            android:id="@+id/tvParticipantName"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:ellipsize="end"
            android:maxLines="1"
            android:textColor="#FFFFFFFF"
            android:textSize="12sp"
            tools:text="John Doe" />

        <!-- Muted mic indicator -->
        <ImageView
            android:id="@+id/ivMicIndicator"
            android:layout_width="16dp"
            android:layout_height="16dp"
            android:layout_marginStart="4dp"
            android:contentDescription="@null"
            android:src="@drawable/ic_mic_off"
            android:tint="#FFFF4444"
            android:visibility="gone" />

        <!-- Video off indicator -->
        <ImageView
            android:id="@+id/ivVideoIndicator"
            android:layout_width="16dp"
            android:layout_height="16dp"
            android:layout_marginStart="4dp"
            android:contentDescription="@null"
            android:src="@drawable/ic_videocam_off"
            android:tint="#FFFF4444"
            android:visibility="gone" />
    </LinearLayout>

    <!-- Connecting spinner overlay -->
    <FrameLayout
        android:id="@+id/participantConnectingOverlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#88000000"
        android:visibility="gone">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:text="Connecting…"
            android:textColor="#BBFFFFFF"
            android:textSize="12sp" />
    </FrameLayout>
</FrameLayout>
