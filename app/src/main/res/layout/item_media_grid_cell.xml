<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/cardMediaCell"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:clipToOutline="true"
    app:cardBackgroundColor="@android:color/black"
    app:cardElevation="0dp"
    app:cardPreventCornerOverlap="false"
    app:cardUseCompatPadding="false">

    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <ImageView
            android:id="@+id/ivMediaThumbnail"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:scaleType="centerCrop"
            tools:src="@tools:sample/backgrounds/scenic" />

    <!-- Play button overlay for videos -->
    <ImageView
        android:id="@+id/ivPlayOverlay"
        android:layout_width="32dp"
        android:layout_height="32dp"
        android:layout_gravity="center"
        android:src="@drawable/ic_play_circle"
        android:visibility="gone"
        tools:visibility="visible" />

    <!-- Video duration overlay -->
    <TextView
        android:id="@+id/tvDuration"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom|start"
        android:layout_margin="4dp"
        android:background="@drawable/bg_timestamp_overlay"
        android:paddingHorizontal="6dp"
        android:paddingVertical="2dp"
        android:textColor="@android:color/white"
        android:textSize="10sp"
        android:visibility="gone"
        tools:text="0:45"
        tools:visibility="visible" />

    <!-- More items count overlay (e.g., "+3") -->
        <FrameLayout
            android:id="@+id/overlayMoreCount"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="?attr/glyphOverlay"
            android:visibility="gone"
            tools:visibility="visible">

            <TextView
                android:id="@+id/tvMoreCount"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:textColor="@android:color/white"
                android:textSize="24sp"
                android:textStyle="bold"
                tools:text="+3" />
        </FrameLayout>

    </FrameLayout>

</com.google.android.material.card.MaterialCardView>
