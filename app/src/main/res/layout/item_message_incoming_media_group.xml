<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:clipChildren="false"
    android:clipToPadding="false"
    android:paddingStart="8dp"
    android:paddingEnd="8dp">

    <!--
      Phase 8: vertical wrapper so the group sender-name label can sit above the
      media bubble. The wrapper is a LinearLayout because the FrameLayout root
      cannot stack children vertically without overlap. The bubble keeps its
      original layout_gravity="start" semantics via the LinearLayout's start
      gravity below. 1:1 chats hide the include and behave identically.
    -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="start"
        android:orientation="vertical">

        <include layout="@layout/layout_group_sender_name" />

        <FrameLayout
            android:id="@+id/messageBubble"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_message_incoming"
            android:padding="0.5dp"
            android:maxWidth="260dp">

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/mediaGridCard"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:clipToOutline="true"
            app:cardBackgroundColor="@android:color/transparent"
            app:cardElevation="0dp"
            app:cardPreventCornerOverlap="false"
            app:cardUseCompatPadding="false">

            <com.glyph.glyph_v3.ui.chat.MediaGridLayout
                android:id="@+id/mediaGridLayout"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:clipChildren="true"
                android:clipToPadding="true" />
        </com.google.android.material.card.MaterialCardView>

        <!-- Progress Indicator -->
        <com.glyph.glyph_v3.ui.chat.CircularProgressView
            android:id="@+id/progressIndicator"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:layout_gravity="center"
            android:visibility="gone" />

        <!-- File size overlay -->
        <TextView
            android:id="@+id/tvFileSize"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="bottom|start"
            android:layout_marginStart="8dp"
            android:layout_marginBottom="8dp"
            android:background="@drawable/bg_timestamp_overlay"
            android:paddingStart="6dp"
            android:paddingTop="2dp"
            android:paddingEnd="6dp"
            android:paddingBottom="2dp"
            android:textColor="@android:color/white"
            android:textSize="10sp"
            tools:text="5.2 MB" />

        <TextView
            android:id="@+id/tvTimestamp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="bottom|end"
            android:layout_marginEnd="8dp"
            android:layout_marginBottom="8dp"
            android:background="@drawable/bg_timestamp_overlay"
            android:paddingStart="6dp"
            android:paddingTop="2dp"
            android:paddingEnd="6dp"
            android:paddingBottom="2dp"
            android:textColor="@android:color/white"
            android:textSize="10sp"
            tools:text="10:30 AM" />

    </FrameLayout>

    </LinearLayout>

</FrameLayout>
