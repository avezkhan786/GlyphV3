<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?android:attr/colorBackground"
    android:fitsSystemWindows="true"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- Profile Card -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:layout_marginTop="16dp"
            android:layout_marginEnd="16dp"
            app:cardBackgroundColor="?attr/glyphSettingsHeroBackground"
            app:cardCornerRadius="16dp"
            app:cardElevation="4dp"
            app:strokeColor="?attr/glyphSettingsHeroStroke"
            app:strokeWidth="1dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <!-- Profile Header Row -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="20dp">

                    <!-- Avatar Container with Camera Badge -->
                    <FrameLayout
                        android:id="@+id/avatarContainer"
                        android:layout_width="80dp"
                        android:layout_height="80dp"
                        android:layout_marginEnd="16dp">

                        <com.google.android.material.imageview.ShapeableImageView
                            android:id="@+id/ivProfile"
                            android:layout_width="80dp"
                            android:layout_height="80dp"
                            android:scaleType="centerCrop"
                            android:src="@drawable/ic_default_avatar"
                            android:background="?attr/glyphAvatarPlaceholder"
                            app:shapeAppearanceOverlay="@style/CircleImageView" />

                        <!-- Upload Progress Overlay -->
                        <FrameLayout
                            android:id="@+id/uploadOverlay"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:visibility="gone"
                            android:background="?attr/glyphOverlay">

                            <LinearLayout
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_gravity="center"
                                android:orientation="vertical"
                                android:gravity="center">

                                <ProgressBar
                                    android:id="@+id/uploadProgressBar"
                                    android:layout_width="24dp"
                                    android:layout_height="24dp"
                                    style="@style/Widget.AppCompat.ProgressBar" />

                                <TextView
                                    android:id="@+id/uploadProgressText"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:layout_marginTop="4dp"
                                    android:text="0%"
                                    android:textColor="@color/white"
                                    android:textSize="12sp"
                                    android:textStyle="bold" />
                            </LinearLayout>
                        </FrameLayout>

                        <!-- Camera Badge -->
                        <FrameLayout
                            android:id="@+id/cameraBadge"
                            android:layout_width="28dp"
                            android:layout_height="28dp"
                            android:layout_gravity="bottom|end"
                            android:layout_marginEnd="2dp"
                            android:layout_marginBottom="2dp"
                            android:background="@drawable/bg_camera_badge">

                            <ImageView
                                android:layout_width="16dp"
                                android:layout_height="16dp"
                                android:layout_gravity="center"
                                android:src="@drawable/ic_camera"
                                app:tint="?attr/glyphIconPrimary" />
                        </FrameLayout>
                    </FrameLayout>

                    <!-- Profile Details -->
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <!-- Name Section -->
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:layout_marginBottom="8dp">

                            <TextView
                                android:id="@+id/tvDisplayName"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Your Name"
                                android:textColor="?attr/glyphSettingsHeroPrimaryText"
                                android:textSize="22sp"
                                android:textStyle="bold"
                                android:maxLines="1"
                                android:ellipsize="end"
                                android:layout_marginBottom="4dp" />

                            <LinearLayout
                                android:id="@+id/nameLabelRow"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:orientation="horizontal"
                                android:gravity="center_vertical">

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="Display name"
                                    android:textColor="?attr/glyphSettingsHeroSecondaryText"
                                    android:textSize="13sp"
                                    android:textStyle="bold" />

                                <ImageView
                                    android:layout_width="16dp"
                                    android:layout_height="16dp"
                                    android:layout_marginStart="4dp"
                                    android:src="@drawable/ic_edit"
                                    app:tint="?attr/glyphSettingsHeroActionIcon" />
                            </LinearLayout>
                        </LinearLayout>

                        <!-- Status Row -->
                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical">

                            <View
                                android:layout_width="12dp"
                                android:layout_height="12dp"
                                android:layout_marginEnd="4dp"
                                android:background="@drawable/bg_online_indicator" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Active now"
                                android:textColor="?attr/glyphOnlineIndicator"
                                android:textSize="13sp"
                                android:textStyle="bold" />
                        </LinearLayout>
                    </LinearLayout>

                    <!-- Refresh Action Button -->
                    <FrameLayout
                        android:id="@+id/refreshAction"
                        android:layout_width="48dp"
                        android:layout_height="48dp"
                        android:background="@drawable/bg_settings_hero_action"
                        android:foreground="?attr/selectableItemBackgroundBorderless">

                        <ImageView
                            android:id="@+id/refreshIcon"
                            android:layout_width="20dp"
                            android:layout_height="20dp"
                            android:layout_gravity="center"
                            android:src="@drawable/ic_refresh"
                            app:tint="?attr/glyphSettingsHeroActionIcon" />
                    </FrameLayout>
                </LinearLayout>

                <!-- About Card -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/aboutCard"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:clickable="true"
                    android:focusable="true"
                    android:foreground="?attr/selectableItemBackground"
                    android:layout_marginBottom="16dp"
                    app:cardBackgroundColor="?attr/glyphSettingsHeroSurface"
                    app:cardCornerRadius="12dp"
                    app:cardElevation="0dp"
                    app:strokeColor="?attr/glyphSettingsHeroStroke"
                    app:strokeWidth="1dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="16dp">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical"
                            android:layout_marginBottom="8dp">

                            <TextView
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="About"
                                android:textColor="?attr/glyphSettingsHeroPrimaryText"
                                android:textSize="14sp"
                                android:textStyle="bold" />

                            <ImageView
                                android:layout_width="16dp"
                                android:layout_height="16dp"
                                android:src="@drawable/ic_edit"
                                app:tint="?attr/glyphSettingsHeroActionIcon" />
                        </LinearLayout>

                        <TextView
                            android:id="@+id/tvAbout"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="Hey there! I am using Glyph."
                            android:textColor="?attr/glyphSettingsHeroSecondaryText"
                            android:textSize="15sp"
                            android:lineSpacingMultiplier="1.4"
                            android:maxLines="2"
                            android:ellipsize="end" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- Profile Footer -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:paddingTop="16dp">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">

                        <ImageView
                            android:layout_width="16dp"
                            android:layout_height="16dp"
                            android:layout_marginEnd="8dp"
                            android:src="@drawable/ic_phone"
                            app:tint="?attr/glyphIconSecondary" />

                        <TextView
                            android:id="@+id/tvPhoneId"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Phone: Unknown"
                            android:textColor="?attr/glyphSettingsHeroSecondaryText"
                            android:textSize="12sp"
                            android:fontFamily="monospace" />
                    </LinearLayout>

                    <LinearLayout
                        android:id="@+id/syncStatus"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:visibility="gone">

                        <ProgressBar
                            android:layout_width="16dp"
                            android:layout_height="16dp"
                            android:layout_marginEnd="6dp"
                            style="@style/Widget.AppCompat.ProgressBar" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Syncing…"
                            android:textColor="?attr/glyphSettingsHeroSecondaryText"
                            android:textSize="12sp"
                            android:textStyle="bold" />
                    </LinearLayout>
                </LinearLayout>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Settings Section -->
        <LinearLayout
            android:id="@+id/settingsContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingTop="10dp">
            <!-- Settings items will be added programmatically -->
        </LinearLayout>

        <!-- Footer -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center"
            android:padding="20dp"
            android:layout_marginTop="20dp">

            <TextView
                android:id="@+id/tvVersion"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Glyph v1.0.0"
                android:textColor="?attr/glyphTextSecondary"
                android:textSize="12sp"
                android:textStyle="bold"
                android:layout_marginBottom="5dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Built with precision by Avez Khan"
                android:textColor="?attr/glyphTextSecondary"
                android:textSize="12sp"
                android:textStyle="bold" />
        </LinearLayout>
    </LinearLayout>
</androidx.core.widget.NestedScrollView>
