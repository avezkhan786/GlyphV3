<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?attr/colorSurface"
    android:fitsSystemWindows="true">

    <!-- AppBar with Toolbar - WhatsApp style -->
    <com.google.android.material.appbar.AppBarLayout
        android:id="@+id/appBarLayout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:fitsSystemWindows="true"
        android:background="?attr/colorSurface"
        app:elevation="4dp"
        app:liftOnScroll="true"
        app:liftOnScrollTargetViewId="@id/recyclerViewChats">

        <!-- WhatsApp-style TopAppBar: 56dp height -->
        <androidx.appcompat.widget.Toolbar
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:paddingStart="16dp"
            android:paddingEnd="8dp"
            app:contentInsetStartWithNavigation="0dp"
            app:title="Glyph"
            app:titleTextColor="@color/white"
            app:titleTextAppearance="@style/GlyphMainToolbarTitle"
            app:layout_scrollFlags="scroll|enterAlways|snap">

            <!-- Action Icons Container -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="end"
                android:orientation="horizontal"
                android:paddingEnd="4dp"
                tools:ignore="RtlSymmetry">

                <!-- Camera Icon -->
                <ImageButton
                    android:id="@+id/btnCamera"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:layout_marginEnd="4dp"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:contentDescription="Camera"
                    android:src="@drawable/ic_camera"
                    app:tint="@color/white" />

                <!-- Search Icon -->
                <ImageButton
                    android:id="@+id/btnSearch"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:layout_marginEnd="4dp"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:contentDescription="Search"
                    android:src="@drawable/ic_search"
                    app:tint="@color/white" />

                <!-- More Options Icon -->
                <ImageButton
                    android:id="@+id/btnMore"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:contentDescription="More options"
                    android:src="@drawable/ic_more_vert"
                    app:tint="@color/white" />

            </LinearLayout>

        </androidx.appcompat.widget.Toolbar>

    </com.google.android.material.appbar.AppBarLayout>

    <!-- Subtle divider separating app bar from content -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:layout_gravity="top"
        android:alpha="0.08"
        android:background="?attr/glyphDivider" />

    <!-- Chat List - header + items via ConcatAdapter -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recyclerViewChats"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:clipToPadding="false"
        android:overScrollMode="never"
        android:paddingBottom="88dp"
        android:scrollbars="none"
        app:layout_behavior="@string/appbar_scrolling_view_behavior"
        tools:itemCount="10"
        tools:listitem="@layout/item_chat_list" />

    <!-- Floating Action Button for New Chat - 56dp -->
    <com.google.android.material.floatingactionbutton.FloatingActionButton
        android:id="@+id/fabNewChat"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom|end"
        android:layout_margin="16dp"
        android:contentDescription="New Chat"
        android:src="@drawable/ic_new_chat"
        app:backgroundTint="?attr/colorPrimary"
        app:elevation="6dp"
        app:fabCustomSize="56dp"
        app:maxImageSize="24dp"
        app:tint="@android:color/white" />

</androidx.coordinatorlayout.widget.CoordinatorLayout>