<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:layout_marginEnd="8dp">

    <androidx.cardview.widget.CardView
        android:id="@+id/cardPreview"
        android:layout_width="72dp"
        android:layout_height="72dp"
        app:cardCornerRadius="10dp"
        app:cardElevation="2dp">

        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent">

            <!-- Thumbnail Image -->
            <ImageView
                android:id="@+id/ivThumbnail"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:scaleType="centerCrop"
                tools:background="@color/glyph_avatar_placeholder" />

            <!-- Video Duration Badge -->
            <TextView
                android:id="@+id/tvDuration"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="bottom|start"
                android:layout_margin="4dp"
                android:background="@drawable/bg_duration_badge"
                android:drawableStart="@drawable/ic_play_small"
                android:drawablePadding="2dp"
                android:paddingHorizontal="4dp"
                android:paddingVertical="1dp"
                android:textColor="@android:color/white"
                android:textSize="9sp"
                android:visibility="gone"
                tools:text="0:45"
                tools:visibility="visible" />

            <!-- Per-Item Quality Badge -->
            <TextView
                android:id="@+id/tvQualityBadge"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="top|end"
                android:layout_margin="3dp"
                android:background="@drawable/bg_quality_badge"
                android:paddingHorizontal="4dp"
                android:paddingVertical="1dp"
                android:textColor="@android:color/white"
                android:textSize="8sp"
                android:textStyle="bold"
                android:visibility="gone"
                tools:text="HD"
                tools:visibility="visible" />
        </FrameLayout>
    </androidx.cardview.widget.CardView>

    <!-- Selection Ring (when item is selected for individual quality) -->
    <View
        android:id="@+id/selectionRing"
        android:layout_width="76dp"
        android:layout_height="76dp"
        android:layout_gravity="center"
        android:background="@drawable/bg_preview_selection_ring"
        android:visibility="gone" />

</FrameLayout>
