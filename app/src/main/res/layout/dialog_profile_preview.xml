<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fitsSystemWindows="false">

    <!-- Semi-transparent background -->
    <View
        android:id="@+id/overlayBg"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="?attr/glyphOverlay" />

    <!-- Preview Card Container -->
    <FrameLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center">

        <!-- Preview Card -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cardPreview"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            app:cardBackgroundColor="?attr/glyphCardBackground"
            app:cardCornerRadius="4dp"
            app:cardElevation="16dp"
            app:strokeWidth="0dp">

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <!-- Header with name -->
                <LinearLayout
                    android:id="@+id/layoutHeader"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="?attr/glyphToolbarBackground"
                    android:paddingHorizontal="16dp"
                    android:paddingVertical="10dp">

                    <TextView
                        android:id="@+id/tvUserName"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Contact Name"
                        android:textColor="?attr/glyphToolbarTitle"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:maxLines="1"
                        android:ellipsize="end" />

                </LinearLayout>

                <!-- Profile Image -->
                <ImageView
                    android:id="@+id/ivProfilePreview"
                    android:layout_width="280dp"
                    android:layout_height="280dp"
                    android:scaleType="centerCrop"
                    android:src="@drawable/ic_default_avatar"
                    android:background="@color/glyph_avatar_placeholder" />

                <!-- Action Buttons Row - Attached to bottom of image -->
                <LinearLayout
                    android:id="@+id/layoutButtons"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center"
                    android:background="?attr/glyphToolbarBackground"
                    android:paddingVertical="12dp">

                    <!-- Chat Button -->
                    <ImageButton
                        android:id="@+id/btnChat"
                        android:layout_width="44dp"
                        android:layout_height="44dp"
                        android:layout_marginHorizontal="16dp"
                        android:background="?attr/selectableItemBackgroundBorderless"
                        android:src="@drawable/ic_chat"
                        app:tint="?attr/glyphToolbarIcon"
                        android:contentDescription="Chat" />

                    <!-- Voice Call Button -->
                    <ImageButton
                        android:id="@+id/btnVoiceCall"
                        android:layout_width="44dp"
                        android:layout_height="44dp"
                        android:layout_marginHorizontal="16dp"
                        android:background="?attr/selectableItemBackgroundBorderless"
                        android:src="@drawable/ic_phone"
                        app:tint="?attr/glyphToolbarIcon"
                        android:contentDescription="Voice Call" />

                    <!-- Video Call Button -->
                    <ImageButton
                        android:id="@+id/btnVideoCall"
                        android:layout_width="44dp"
                        android:layout_height="44dp"
                        android:layout_marginHorizontal="16dp"
                        android:background="?attr/selectableItemBackgroundBorderless"
                        android:src="@drawable/ic_video_call"
                        app:tint="?attr/glyphToolbarIcon"
                        android:contentDescription="Video Call" />

                    <!-- Info Button -->
                    <ImageButton
                        android:id="@+id/btnInfo"
                        android:layout_width="44dp"
                        android:layout_height="44dp"
                        android:layout_marginHorizontal="16dp"
                        android:background="?attr/selectableItemBackgroundBorderless"
                        android:src="@drawable/ic_info"
                        app:tint="?attr/glyphToolbarIcon"
                        android:contentDescription="Info" />

                </LinearLayout>

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

    </FrameLayout>

</FrameLayout>
