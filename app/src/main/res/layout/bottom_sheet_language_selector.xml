<?xml version="1.0" encoding="utf-8"?>
<!--
  Bottom sheet for language selection.
  Simple grid of language options.
-->
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="16dp"
    android:background="?attr/glyphBackground">

    <!-- Handle bar -->
    <View
        android:layout_width="40dp"
        android:layout_height="4dp"
        android:layout_gravity="center_horizontal"
        android:background="@drawable/bottom_sheet_handle"
        android:layout_marginBottom="12dp" />

    <!-- Title -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Select Language"
        android:textSize="18sp"
        android:textColor="?attr/glyphTextPrimary"
        android:fontFamily="sans-serif-medium"
        android:layout_marginBottom="16dp" />

    <!-- Search Bar -->
    <EditText
        android:id="@+id/etSearchLanguage"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:background="@drawable/bg_search_bar"
        android:drawableStart="@android:drawable/ic_menu_search"
        android:drawableTint="?attr/glyphTextSecondary"
        android:drawablePadding="12dp"
        android:hint="Search language"
        android:inputType="textCapWords"
        android:maxLines="1"
        android:paddingStart="12dp"
        android:paddingEnd="12dp"
        android:textColor="?attr/glyphTextPrimary"
        android:textColorHint="?attr/glyphTextSecondary"
        android:textSize="16sp"
        android:layout_marginBottom="12dp" />

    <!-- Language list -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvLanguages"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:maxHeight="400dp"
        android:clipToPadding="false"
        android:paddingBottom="16dp" />

</LinearLayout>
