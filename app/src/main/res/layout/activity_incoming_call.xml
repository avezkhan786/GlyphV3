<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/rootLayout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FF000000"
    android:clipChildren="false"
    android:clipToPadding="false">

    <ImageView
        android:id="@+id/voiceFallbackBackground"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:contentDescription="@null"
        android:scaleType="centerCrop"
        android:src="@drawable/voice_call_bg" />

    <FrameLayout
        android:id="@+id/localVideoPreviewContainer"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:visibility="gone">

        <org.webrtc.SurfaceViewRenderer
            android:id="@+id/localVideoPreviewBg"
            android:layout_width="match_parent"
            android:layout_height="match_parent" />
    </FrameLayout>

    <View
        android:id="@+id/scrimOverlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#33000000" />

    <View
        android:layout_width="match_parent"
        android:layout_height="228dp"
        android:layout_gravity="top"
        android:background="@drawable/bg_call_top_scrim" />

    <View
        android:layout_width="match_parent"
        android:layout_height="312dp"
        android:layout_gravity="bottom"
        android:background="@drawable/bg_call_bottom_scrim" />

    <FrameLayout
        android:id="@+id/incomingCallContentRoot"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:clipChildren="false"
        android:clipToPadding="false"
        android:paddingHorizontal="24dp">

        <LinearLayout
            android:id="@+id/callerInfoGroup"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_gravity="top|center_horizontal"
            android:gravity="center_horizontal"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tvCallerName"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="sans-serif-medium"
                android:shadowColor="#80000000"
                android:shadowDx="0"
                android:shadowDy="2"
                android:shadowRadius="16"
                android:textColor="#FFFFFFFF"
                android:textSize="32sp"
                android:textStyle="bold"
                tools:text="Nazia" />

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <ImageView
                    android:id="@+id/ivCallTypeIcon"
                    android:layout_width="18dp"
                    android:layout_height="18dp"
                    android:layout_marginEnd="8dp"
                    android:contentDescription="@null"
                    android:src="@drawable/ic_phone"
                    android:tint="#D9FFFFFF" />

                <TextView
                    android:id="@+id/tvCallerInfo"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:ellipsize="end"
                    android:maxLines="1"
                    android:shadowColor="#66000000"
                    android:shadowDx="0"
                    android:shadowDy="1"
                    android:shadowRadius="10"
                    android:textColor="#D9FFFFFF"
                    android:textSize="15sp"
                    tools:text="+91 94809 34782" />
            </LinearLayout>

            <FrameLayout
                android:id="@+id/avatarShell"
                android:layout_width="134dp"
                android:layout_height="134dp"
                android:layout_marginTop="30dp"
                android:background="@drawable/bg_call_avatar_shell"
                android:elevation="12dp">

                <ImageView
                    android:id="@+id/ivCallerAvatar"
                    android:layout_width="122dp"
                    android:layout_height="122dp"
                    android:layout_gravity="center"
                    android:background="@drawable/bg_call_avatar"
                    android:clipToOutline="true"
                    android:contentDescription="@null"
                    android:scaleType="centerCrop"
                    android:src="@drawable/ic_default_avatar" />
            </FrameLayout>

            <LinearLayout
                android:id="@+id/videoHintContainer"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="22dp"
                android:background="@drawable/bg_video_hint_pill"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingStart="18dp"
                android:paddingTop="12dp"
                android:paddingEnd="20dp"
                android:paddingBottom="12dp"
                android:visibility="gone">

                <ImageView
                    android:id="@+id/ivVideoToggleHint"
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:layout_marginEnd="10dp"
                    android:contentDescription="@null"
                    android:src="@drawable/ic_videocam_off"
                    android:tint="#FFFFFFFF" />

                <TextView
                    android:id="@+id/tvVideoHintText"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="sans-serif-medium"
                    android:text="Turn off your video"
                    android:textColor="#FFFFFFFF"
                    android:textSize="14sp" />
            </LinearLayout>
        </LinearLayout>

        <LinearLayout
            android:id="@+id/incomingCallBottomActions"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_gravity="bottom|center_horizontal"
            android:baselineAligned="false"
            android:clipChildren="false"
            android:clipToPadding="false"
            android:gravity="center"
            android:orientation="horizontal"
            android:weightSum="3"
            android:paddingTop="12dp"
            android:paddingBottom="24dp">

            <LinearLayout
                android:id="@+id/declineSwipeContainer"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:clipChildren="false"
                android:clipToPadding="false"
                android:gravity="center_horizontal"
                android:orientation="vertical">

                <FrameLayout
                    android:id="@+id/declineButtonStack"
                    android:layout_width="90dp"
                    android:layout_height="126dp"
                    android:clipChildren="false"
                    android:clipToPadding="false">

                    <FrameLayout
                        android:id="@+id/btnDecline"
                        android:layout_width="76dp"
                        android:layout_height="76dp"
                        android:layout_gravity="bottom|center_horizontal"
                        android:background="@drawable/bg_call_end_button"
                        android:clickable="true"
                        android:elevation="10dp"
                        android:focusable="true">

                        <ImageView
                            android:id="@+id/ivDeclineIcon"
                            android:layout_width="30dp"
                            android:layout_height="30dp"
                            android:layout_gravity="center"
                            android:contentDescription="@null"
                            android:rotation="135"
                            android:src="@drawable/ic_call"
                            android:tint="#FFFFFFFF" />
                    </FrameLayout>
                </FrameLayout>

                <TextView
                    android:id="@+id/tvDeclineLabel"
                    android:layout_width="110dp"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:gravity="center"
                    android:maxLines="1"
                    android:text="Decline"
                    android:textColor="#D9FFFFFF"
                    android:textSize="13sp" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/acceptSwipeContainer"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:clipChildren="false"
                android:clipToPadding="false"
                android:gravity="center_horizontal"
                android:orientation="vertical">

                <FrameLayout
                    android:id="@+id/acceptButtonStack"
                    android:layout_width="90dp"
                    android:layout_height="126dp"
                    android:clipChildren="false"
                    android:clipToPadding="false">

                    <LinearLayout
                        android:id="@+id/swipeArrowContainer"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="bottom|center_horizontal"
                        android:layout_marginBottom="94dp"
                        android:gravity="center_horizontal"
                        android:orientation="vertical">

                        <ImageView
                            android:id="@+id/ivSwipeArrow1"
                            android:layout_width="14dp"
                            android:layout_height="14dp"
                            android:layout_marginBottom="-6dp"
                            android:alpha="0.08"
                            android:src="@drawable/ic_camera_chevron_up"
                            android:tint="#CCFFFFFF" />

                        <ImageView
                            android:id="@+id/ivSwipeArrow2"
                            android:layout_width="14dp"
                            android:layout_height="14dp"
                            android:layout_marginBottom="-6dp"
                            android:alpha="0.12"
                            android:src="@drawable/ic_camera_chevron_up"
                            android:tint="#D9FFFFFF" />

                        <ImageView
                            android:id="@+id/ivSwipeArrow3"
                            android:layout_width="14dp"
                            android:layout_height="14dp"
                            android:layout_marginBottom="-6dp"
                            android:alpha="0.16"
                            android:src="@drawable/ic_camera_chevron_up"
                            android:tint="#E6FFFFFF" />

                        <ImageView
                            android:id="@+id/ivSwipeArrow4"
                            android:layout_width="14dp"
                            android:layout_height="14dp"
                            android:alpha="0.2"
                            android:src="@drawable/ic_camera_chevron_up"
                            android:tint="#F2FFFFFF" />
                    </LinearLayout>

                    <FrameLayout
                        android:id="@+id/btnAccept"
                        android:layout_width="76dp"
                        android:layout_height="76dp"
                        android:layout_gravity="bottom|center_horizontal"
                        android:background="@drawable/bg_call_accept_button"
                        android:clickable="true"
                        android:elevation="12dp"
                        android:focusable="true">

                        <ImageView
                            android:id="@+id/ivAcceptIcon"
                            android:layout_width="32dp"
                            android:layout_height="32dp"
                            android:layout_gravity="center"
                            android:contentDescription="@null"
                            android:src="@drawable/ic_videocam"
                            android:tint="#FFFFFFFF" />
                    </FrameLayout>
                </FrameLayout>

                <TextView
                    android:id="@+id/tvAcceptLabel"
                    android:layout_width="110dp"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:gravity="center"
                    android:maxLines="1"
                    android:text="Swipe up to accept"
                    android:textColor="#D9FFFFFF"
                    android:textSize="13sp" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:clipChildren="false"
                android:clipToPadding="false"
                android:gravity="center_horizontal"
                android:orientation="vertical">

                <FrameLayout
                    android:id="@+id/messageButtonStack"
                    android:layout_width="90dp"
                    android:layout_height="126dp"
                    android:clipChildren="false"
                    android:clipToPadding="false">

                    <FrameLayout
                        android:id="@+id/btnMessage"
                        android:layout_width="76dp"
                        android:layout_height="76dp"
                        android:layout_gravity="bottom|center_horizontal"
                        android:background="@drawable/bg_call_message_button"
                        android:clickable="true"
                        android:elevation="10dp"
                        android:focusable="true">

                        <ImageView
                            android:id="@+id/ivMessageIcon"
                            android:layout_width="28dp"
                            android:layout_height="28dp"
                            android:layout_gravity="center"
                            android:contentDescription="@null"
                            android:src="@drawable/ic_chat"
                            android:tint="#FFFFFFFF" />
                    </FrameLayout>
                </FrameLayout>

                <TextView
                    android:layout_width="110dp"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:gravity="center"
                    android:maxLines="1"
                    android:text="Message"
                    android:textColor="#D9FFFFFF"
                    android:textSize="13sp" />
            </LinearLayout>
        </LinearLayout>
    </FrameLayout>
</FrameLayout>
