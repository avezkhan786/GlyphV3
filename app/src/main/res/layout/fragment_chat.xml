<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_glyph_gradient"
    android:fitsSystemWindows="true">

    <!-- AppBar with Custom Chat Header - Glassmorphism -->
    <!-- Glass effect applied programmatically in ChatFragment.kt -->
    <com.google.android.material.appbar.AppBarLayout
        android:id="@+id/appBarLayout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:fitsSystemWindows="true"
        android:background="@android:color/transparent"
        app:elevation="0dp">

        <!-- Custom Toolbar with User Info -->
        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/toolbarContainer"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            android:paddingEnd="4dp">

            <!-- Back Arrow -->
            <ImageButton
                android:id="@+id/btnBack"
                android:layout_width="41dp"
                android:layout_height="41dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:src="@drawable/ic_arrow_back"
                android:contentDescription="Back"
                app:tint="@color/glyph_primary_dark"
                android:padding="8dp"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintBottom_toBottomOf="parent"
                android:layout_marginStart="4dp" />

            <!-- Profile Picture -->
            <com.google.android.material.imageview.ShapeableImageView
                android:id="@+id/ivProfilePicture"
                android:layout_width="41dp"
                android:layout_height="41dp"
                android:layout_marginStart="4dp"
                android:background="@drawable/bg_avatar_circle"
                android:contentDescription="Profile Picture"
                android:scaleType="centerCrop"
                app:shapeAppearanceOverlay="@style/CircularImageView"
                app:layout_constraintStart_toEndOf="@id/btnBack"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintBottom_toBottomOf="parent"
                tools:src="@drawable/ic_default_avatar" />

            <!-- User Name -->
            <TextView
                android:id="@+id/tvUserName"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="12dp"
                android:layout_marginEnd="8dp"
                android:ellipsize="end"
                android:maxLines="1"
                android:textColor="@color/glyph_text_primary"
                android:textSize="16sp"
                android:fontFamily="sans-serif-medium"
                app:layout_constraintStart_toEndOf="@id/ivProfilePicture"
                app:layout_constraintEnd_toStartOf="@id/btnVideoCall"
                app:layout_constraintTop_toTopOf="@id/ivProfilePicture"
                app:layout_constraintBottom_toTopOf="@id/tvLastSeen"
                app:layout_constraintVertical_chainStyle="packed"
                tools:text="John Doe" />

            <!-- Last Seen / Online Status -->
            <TextView
                android:id="@+id/tvLastSeen"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:ellipsize="end"
                android:maxLines="1"
                android:textColor="@color/glyph_text_secondary"
                android:textSize="12sp"
                app:layout_constraintStart_toStartOf="@id/tvUserName"
                app:layout_constraintEnd_toStartOf="@id/btnVideoCall"
                app:layout_constraintTop_toBottomOf="@id/tvUserName"
                app:layout_constraintBottom_toBottomOf="@id/ivProfilePicture"
                tools:text="online" />

            <!-- Video Call Button -->
            <ImageButton
                android:id="@+id/btnVideoCall"
                android:layout_width="37dp"
                android:layout_height="37dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:src="@drawable/ic_video_call"
                android:contentDescription="Video Call"
                android:padding="6dp"
                app:layout_constraintEnd_toStartOf="@id/btnVoiceCall"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintBottom_toBottomOf="parent" />

            <!-- Voice Call Button -->
            <ImageButton
                android:id="@+id/btnVoiceCall"
                android:layout_width="37dp"
                android:layout_height="37dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:src="@drawable/ic_voice_call"
                android:contentDescription="Voice Call"
                android:padding="6dp"
                app:layout_constraintEnd_toStartOf="@id/btnLightning"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintBottom_toBottomOf="parent" />

            <!-- Lightning Button -->
            <ImageButton
                android:id="@+id/btnLightning"
                android:layout_width="37dp"
                android:layout_height="37dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:src="@drawable/ic_lightning"
                android:contentDescription="Quick Actions"
                android:padding="6dp"
                app:layout_constraintEnd_toStartOf="@id/btnMenu"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintBottom_toBottomOf="parent" />

            <!-- Menu Button -->
            <ImageButton
                android:id="@+id/btnMenu"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:src="@drawable/ic_more_vert"
                android:contentDescription="Menu"
                android:padding="6dp"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintBottom_toBottomOf="parent" />

        </androidx.constraintlayout.widget.ConstraintLayout>

    </com.google.android.material.appbar.AppBarLayout>

    <!-- Messages RecyclerView -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recyclerViewMessages"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:clipToPadding="false"
        android:paddingTop="8dp"
        android:paddingBottom="8dp"
        android:scrollbars="none"
        android:overScrollMode="never"
        app:layout_behavior="@string/appbar_scrolling_view_behavior"
        tools:listitem="@layout/item_message_outgoing" />

    <!-- Input Area -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/layoutInput"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:background="@android:color/transparent"
        android:paddingStart="12dp"
        android:paddingTop="10dp"
        android:paddingEnd="12dp"
        android:paddingBottom="10dp">

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/chatInputCard"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:minHeight="@dimen/chat_input_height"
            android:layout_marginEnd="8dp"
            app:cardBackgroundColor="?attr/colorSurfaceVariant"
            app:cardCornerRadius="@dimen/chat_input_corner_radius"
            app:cardElevation="0dp"
            app:cardPreventCornerOverlap="false"
            app:cardUseCompatPadding="false"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toStartOf="@+id/sendActionContainer"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent">

            <androidx.constraintlayout.widget.ConstraintLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:minHeight="@dimen/chat_input_height"
                android:paddingStart="4dp"
                android:paddingEnd="4dp">

                <ImageButton
                    android:id="@+id/btnAdd"
                    android:layout_width="48dp"
                    android:layout_height="0dp"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:src="@drawable/ic_add_2"
                    android:contentDescription="@string/chat_input_attachment_desc"
                    app:tint="?attr/colorOnSurface"
                    android:padding="11dp"
                    android:scaleType="fitCenter"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent" />

                <EditText
                    android:id="@+id/etMessageInput"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:minHeight="@dimen/chat_input_height"
                    android:layout_marginStart="0dp"
                    android:layout_marginEnd="0dp"
                    android:background="@null"
                    android:gravity="center_vertical"
                    android:hint="@string/chat_input_hint"
                    android:inputType="textCapSentences"
                    android:maxLines="1"
                    android:singleLine="true"
                    android:scrollHorizontally="true"
                    android:paddingTop="8dp"
                    android:paddingBottom="8dp"
                    android:paddingEnd="4dp"
                    android:textColor="@color/glyph_text_primary"
                    android:textColorHint="@color/glyph_text_hint"
                    android:textSize="16sp"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintEnd_toStartOf="@+id/btnEmoji"
                    app:layout_constraintStart_toEndOf="@id/btnAdd"
                    app:layout_constraintTop_toTopOf="parent" />

                <ImageButton
                    android:id="@+id/btnEmoji"
                    android:layout_width="48dp"
                    android:layout_height="0dp"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:contentDescription="@string/chat_input_emoji_desc"
                    android:src="@drawable/ic_emoji"
                    app:tint="?attr/colorOnSurface"
                    android:padding="11dp"
                    android:scaleType="fitCenter"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintEnd_toStartOf="@id/btnCamera"
                    app:layout_constraintTop_toTopOf="parent" />

                <ImageButton
                    android:id="@+id/btnCamera"
                    android:layout_width="48dp"
                    android:layout_height="0dp"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:contentDescription="@string/chat_input_camera_desc"
                    android:src="@drawable/ic_camera"
                    app:tint="?attr/colorOnSurface"
                    android:padding="11dp"
                    android:scaleType="fitCenter"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintTop_toTopOf="parent" />

            </androidx.constraintlayout.widget.ConstraintLayout>
        </com.google.android.material.card.MaterialCardView>

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/sendActionContainer"
            android:layout_width="@dimen/chat_send_button_size"
            android:layout_height="@dimen/chat_send_button_size"
            app:cardBackgroundColor="?attr/glyphScrollFabIcon"
            app:cardCornerRadius="@dimen/chat_send_button_size"
            app:cardElevation="0dp"
            app:cardUseCompatPadding="false"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent">

            <ImageButton
                android:id="@+id/btnSend"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="@android:color/transparent"
                android:contentDescription="@string/chat_input_send_desc"
                android:src="@drawable/ic_send"
                android:padding="14dp"
                android:scaleType="fitCenter"
                app:tint="?attr/glyphToolbarBackground" />

        </com.google.android.material.card.MaterialCardView>

    </androidx.constraintlayout.widget.ConstraintLayout>

</androidx.coordinatorlayout.widget.CoordinatorLayout>