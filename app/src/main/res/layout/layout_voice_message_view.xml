<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="240dp"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:gravity="center_vertical"
    android:padding="0dp">

    <!-- Play/Pause Button Area -->
    <FrameLayout
        android:id="@+id/btnPlayPause"
        android:layout_width="44dp"
        android:layout_height="44dp"
        android:layout_marginEnd="12dp">

        <com.google.android.material.imageview.ShapeableImageView
            android:id="@+id/ivAvatar"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:scaleType="centerCrop"
            android:visibility="gone"
            app:shapeAppearanceOverlay="@style/ShapeAppearance.Material3.Corner.Full" />

        <View
            android:id="@+id/avatarOverlay"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:backgroundTint="@android:color/transparent"
            android:visibility="gone"
            android:background="@drawable/bg_circle_overlay" />
            
        <View
            android:id="@+id/btnBackground"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="@drawable/bg_circle_overlay"
            android:visibility="visible" />

        <com.google.android.material.progressindicator.CircularProgressIndicator
            android:id="@+id/progressIndicator"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:indeterminate="false"
            app:indicatorColor="#4CAF50"
            app:trackColor="@android:color/transparent"
            app:trackThickness="2.5dp"
            android:layout_gravity="center"
            android:padding="0dp"
            app:indicatorSize="44dp" 
            style="@style/Widget.Material3.CircularProgressIndicator" />

        <ImageView
            android:id="@+id/ivPlayIcon"
            android:layout_width="26dp"
            android:layout_height="26dp"
            android:layout_gravity="center"
            android:src="@drawable/ic_play"
            app:tint="@android:color/white" />

    </FrameLayout>

    <!-- Waveform & Meta -->
    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical">

        <com.glyph.glyph_v3.ui.chat.WaveformView
            android:id="@+id/waveformView"
            android:layout_width="match_parent"
            android:layout_height="36dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <TextView
                android:id="@+id/tvDuration"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:textSize="13sp"
                android:textStyle="normal"
                android:textColor="@android:color/white"
                tools:text="0:15" />

            <!-- Meta Container -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/tvTimestamp"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="12sp"
                    android:textColor="#99FFFFFF"
                    tools:text="10:30 AM" />

                <ImageView
                    android:id="@+id/ivPlayed"
                    android:layout_width="16dp"
                    android:layout_height="16dp"
                    android:layout_marginStart="6dp"
                    android:scaleType="fitCenter"
                    android:src="@drawable/ic_voice_played"
                    app:tint="#4CAF50"
                    android:visibility="gone" />

                <ImageView
                    android:id="@+id/ivStatus"
                    android:layout_width="16dp"
                    android:layout_height="16dp"
                    android:layout_marginStart="5dp"
                    android:scaleType="fitCenter"
                    android:src="@drawable/ic_double_check"
                    app:tint="#4FC3F7"
                    android:visibility="gone" />
            </LinearLayout>

        </LinearLayout>
    </LinearLayout>

</LinearLayout>
