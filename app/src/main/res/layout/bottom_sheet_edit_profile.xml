<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@drawable/bg_bottom_sheet_rounded"
    android:paddingStart="24dp"
    android:paddingEnd="24dp"
    android:paddingTop="16dp"
    android:paddingBottom="28dp">

    <!-- Handle -->
    <View
        android:layout_width="48dp"
        android:layout_height="4dp"
        android:layout_gravity="center_horizontal"
        android:layout_marginBottom="16dp"
        android:background="@drawable/bg_bottom_sheet_handle" />

    <!-- Title -->
    <TextView
        android:id="@+id/editModalTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Edit Display Name"
        android:textColor="?attr/glyphTextPrimary"
        android:textSize="20sp"
        android:textStyle="bold"
        android:layout_marginBottom="16dp" />

    <!-- Input Field -->
    <EditText
        android:id="@+id/editModalInput"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:minHeight="48dp"
        android:background="@drawable/bg_input_rounded"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:paddingTop="12dp"
        android:paddingBottom="12dp"
        android:gravity="top|start"
        android:scrollHorizontally="false"
        android:minLines="1"
        android:textColor="?attr/glyphTextPrimary"
        android:textSize="16sp"
        android:hint="Set a display name"
        android:textColorHint="?attr/glyphTextHint"
        android:inputType="text"
        android:maxLines="4" />

    <!-- Error Message -->
    <TextView
        android:id="@+id/editModalError"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:textColor="?attr/glyphError"
        android:textSize="13sp"
        android:visibility="gone" />

    <!-- Meta Row: Description + Counter -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginTop="12dp">

        <TextView
            android:id="@+id/editModalDescription"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginEnd="12dp"
            android:text="This name appears across your Glyph profile."
            android:textColor="?attr/glyphTextSecondary"
            android:textSize="12sp" />

        <TextView
            android:id="@+id/editModalCounter"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="0/50"
            android:textColor="?attr/glyphTextHint"
            android:textSize="12sp"
            android:fontFamily="monospace" />
    </LinearLayout>

    <!-- Buttons Row -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginTop="24dp">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnCancel"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginEnd="8dp"
            android:text="Cancel"
            android:textColor="?attr/glyphTextPrimary"
            android:textSize="15sp"
            android:textStyle="bold"
            app:cornerRadius="12dp"
            app:strokeColor="?attr/glyphBorder"
            app:strokeWidth="1dp"
            app:backgroundTint="?attr/glyphSheetBackground"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnSave"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="8dp"
            android:text="Save"
            android:textColor="?attr/glyphTextInverse"
            android:textSize="15sp"
            android:textStyle="bold"
            app:cornerRadius="12dp"
            app:backgroundTint="?attr/glyphPrimary"
            app:elevation="3dp" />
    </LinearLayout>
</LinearLayout>
