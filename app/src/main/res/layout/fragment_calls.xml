<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?attr/glyphSurface">

    <com.google.android.material.appbar.AppBarLayout
        android:id="@+id/appBarLayout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="?attr/glyphToolbarBackground"
        app:elevation="0dp"
        app:liftOnScroll="false">

        <androidx.appcompat.widget.Toolbar
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:paddingStart="16dp"
            android:paddingEnd="8dp"
            app:contentInsetStartWithNavigation="0dp"
            app:layout_scrollFlags="noScroll"
            app:title="@string/calls_title"
            app:titleTextAppearance="@style/GlyphToolbarTitle"
            app:titleTextColor="?attr/glyphToolbarTitle">

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="end"
                android:orientation="horizontal"
                android:paddingEnd="4dp"
                tools:ignore="RtlSymmetry">

                <ImageButton
                    android:id="@+id/btnSearch"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:layout_marginEnd="4dp"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:contentDescription="@string/calls_search"
                    android:src="@drawable/ic_search"
                    app:tint="?attr/glyphToolbarIcon" />

                <ImageButton
                    android:id="@+id/btnMore"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:contentDescription="@string/calls_more_options"
                    android:src="@drawable/ic_more_vert"
                    app:tint="?attr/glyphToolbarIcon" />
            </LinearLayout>
        </androidx.appcompat.widget.Toolbar>

        <androidx.appcompat.widget.Toolbar
            android:id="@+id/toolbarSelection"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:paddingStart="4dp"
            android:paddingEnd="8dp"
            android:visibility="gone"
            app:contentInsetStartWithNavigation="0dp"
            app:layout_scrollFlags="noScroll"
            app:navigationIcon="@drawable/ic_arrow_back"
            app:titleTextAppearance="@style/GlyphToolbarTitle"
            app:titleTextColor="?attr/glyphToolbarTitle">

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="end"
                android:orientation="horizontal"
                android:paddingEnd="4dp"
                tools:ignore="RtlSymmetry">

                <ImageButton
                    android:id="@+id/btnSelectionDelete"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:layout_marginEnd="4dp"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:contentDescription="@string/calls_selection_delete"
                    android:src="@drawable/ic_call_bin"
                    app:tint="?attr/glyphToolbarIcon" />

                <ImageButton
                    android:id="@+id/btnSelectionFavorite"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:layout_marginEnd="4dp"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:contentDescription="@string/calls_selection_favorite"
                    android:src="@drawable/ic_call_favorite_outline"
                    app:tint="?attr/glyphToolbarIcon" />

                <ImageButton
                    android:id="@+id/btnSelectionMore"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:contentDescription="@string/calls_selection_more"
                    android:src="@drawable/ic_more_vert"
                    app:tint="?attr/glyphToolbarIcon" />
            </LinearLayout>
        </androidx.appcompat.widget.Toolbar>

    </com.google.android.material.appbar.AppBarLayout>

    <LinearLayout
        android:id="@+id/contentContainer"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        app:layout_behavior="@string/appbar_scrolling_view_behavior">

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/recyclerViewHeader"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:clipToPadding="false"
            android:nestedScrollingEnabled="false"
            android:overScrollMode="never"
            android:paddingStart="14dp"
            android:paddingTop="8dp"
            android:paddingEnd="14dp"
            android:paddingBottom="6dp"
            android:scrollbars="none"
            tools:itemCount="5"
            tools:listitem="@layout/item_calls_header_action" />

        <TextView
            android:id="@+id/tvRecentHeader"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingStart="18dp"
            android:paddingTop="8dp"
            android:paddingEnd="18dp"
            android:paddingBottom="10dp"
            android:text="@string/calls_recent"
            android:textColor="?attr/glyphTextPrimary"
            android:textSize="16sp"
            android:textStyle="bold" />

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/recyclerViewCalls"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:clipToPadding="false"
            android:overScrollMode="never"
            android:scrollbars="none"
            tools:itemCount="7"
            tools:listitem="@layout/item_call_history" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/emptyState"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:gravity="center"
        android:orientation="vertical"
        android:padding="32dp"
        android:visibility="gone">

        <ImageView
            android:layout_width="72dp"
            android:layout_height="72dp"
            android:alpha="0.7"
            android:contentDescription="@null"
            android:src="@drawable/ic_call_glyph"
            app:tint="?attr/glyphIconSecondary" />

        <TextView
            android:id="@+id/tvEmptyTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="@string/calls_empty_title"
            android:textColor="?attr/glyphTextPrimary"
            android:textSize="20sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tvEmptySubtitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:gravity="center"
            android:text="@string/calls_empty_subtitle"
            android:textColor="?attr/glyphTextSecondary"
            android:textSize="14sp" />
    </LinearLayout>

    <ProgressBar
        android:id="@+id/progressCalls"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:visibility="gone" />

    <com.google.android.material.floatingactionbutton.FloatingActionButton
        android:id="@+id/fabNewCall"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom|end"
        android:layout_marginEnd="16dp"
        android:layout_marginBottom="45dp"
        android:contentDescription="@string/calls_new_call"
        android:src="@drawable/ic_call_add"
        app:backgroundTint="#21c063"
        app:elevation="6dp"
        app:maxImageSize="24dp"
        app:tint="#0b1014" />

</androidx.coordinatorlayout.widget.CoordinatorLayout>