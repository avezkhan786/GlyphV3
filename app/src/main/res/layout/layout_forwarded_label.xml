<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/forwardedLabelContainer"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:gravity="center_vertical"
    android:orientation="horizontal"
    android:paddingStart="10dp"
    android:paddingTop="6dp"
    android:paddingEnd="10dp"
    android:paddingBottom="4dp"
    android:visibility="gone"
    tools:visibility="visible">

    <ImageView
        android:id="@+id/ivForwardedLabel"
        android:layout_width="14dp"
        android:layout_height="14dp"
        android:layout_marginEnd="5dp"
        android:contentDescription="@null"
        android:src="@drawable/ic_forwarded_label"
        app:tint="#667781" />

    <TextView
        android:id="@+id/tvForwardedLabel"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:fontFamily="sans-serif-medium"
        android:includeFontPadding="false"
        android:text="Forwarded"
        android:textColor="#667781"
        android:textSize="12sp"
        tools:text="Forwarded" />
</LinearLayout>