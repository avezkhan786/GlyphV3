<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="20dp"
    android:background="?attr/glyphSurface">

    <!-- Header: icon + title -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingBottom="16dp">

        <ImageView
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:src="@drawable/ic_clock"
            app:tint="?attr/glyphSendButton"
            android:contentDescription="@null" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:paddingStart="12dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Share live location for"
                android:textAppearance="?attr/textAppearanceHeadline6"
                android:textColor="?attr/glyphTextPrimary" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Choose how long to share your location"
                android:textAppearance="?attr/textAppearanceBody2"
                android:textColor="?attr/glyphTextSecondary"
                android:paddingTop="2dp" />
        </LinearLayout>
    </LinearLayout>

    <!-- Duration options card -->
    <com.google.android.material.card.MaterialCardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:cardBackgroundColor="?attr/glyphCardBackground"
        app:cardCornerRadius="12dp"
        app:cardElevation="0dp"
        app:strokeColor="?attr/glyphDivider"
        app:strokeWidth="1dp"
        android:layout_marginBottom="16dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- Option 1: 15 minutes -->
            <LinearLayout
                android:id="@+id/option_15min"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:background="?attr/selectableItemBackground"
                android:focusable="true"
                android:clickable="true">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="15 minutes"
                    android:textAppearance="?attr/textAppearanceBody1"
                    android:textColor="?attr/glyphTextPrimary" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Short-term"
                    android:textAppearance="?attr/textAppearanceCaption"
                    android:textColor="?attr/glyphTextSecondary" />
            </LinearLayout>

            <!-- Divider -->
            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:layout_marginStart="16dp"
                android:background="?attr/glyphDivider" />

            <!-- Option 2: 1 hour -->
            <LinearLayout
                android:id="@+id/option_1hour"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:background="?attr/selectableItemBackground"
                android:focusable="true"
                android:clickable="true">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="1 hour"
                    android:textAppearance="?attr/textAppearanceBody1"
                    android:textColor="?attr/glyphTextPrimary" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Recommended"
                    android:textAppearance="?attr/textAppearanceCaption"
                    android:textColor="?attr/glyphSendButton" />
            </LinearLayout>

            <!-- Divider -->
            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:layout_marginStart="16dp"
                android:background="?attr/glyphDivider" />

            <!-- Option 3: 8 hours -->
            <LinearLayout
                android:id="@+id/option_8hours"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:background="?attr/selectableItemBackground"
                android:focusable="true"
                android:clickable="true">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="8 hours"
                    android:textAppearance="?attr/textAppearanceBody1"
                    android:textColor="?attr/glyphTextPrimary" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Extended"
                    android:textAppearance="?attr/textAppearanceCaption"
                    android:textColor="?attr/glyphTextSecondary" />
            </LinearLayout>

        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

    <com.google.android.material.card.MaterialCardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:cardBackgroundColor="?attr/glyphCardBackground"
        app:cardCornerRadius="12dp"
        app:cardElevation="0dp"
        app:strokeColor="?attr/glyphDivider"
        app:strokeWidth="1dp"
        android:layout_marginBottom="16dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <CheckBox
                android:id="@+id/checkbox_camera_share"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Allow the other user to view my live camera feed along with my live location"
                android:textColor="?attr/glyphTextPrimary"
                android:textAppearance="?attr/textAppearanceBody1"
                android:buttonTint="?attr/glyphSendButton" />

            <TextView
                android:id="@+id/text_camera_share_explanation"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:paddingStart="4dp"
                android:text="If enabled, the other user will be able to view your live camera feed while your live location sharing is active."
                android:textAppearance="?attr/textAppearanceBody2"
                android:textColor="?attr/glyphTextSecondary" />
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

    <!-- Cancel button row -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="end">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_cancel"
            style="?attr/materialButtonOutlinedStyle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Cancel"
            android:textColor="?attr/glyphTextSecondary"
            app:strokeColor="?attr/glyphDivider" />
    </LinearLayout>
</LinearLayout>
