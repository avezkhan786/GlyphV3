<?xml version="1.0" encoding="utf-8"?>
<!--
    Fragment layout for a single picker tab.
    Contains a search bar and a RecyclerView grid.
-->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="?attr/glyphSurface">

    <!-- Emoji Source Switcher (Only visible for Emoji Tab) -->
    <LinearLayout
        android:id="@+id/layoutEmojiSource"
        android:layout_width="match_parent"
        android:layout_height="36dp"
        android:layout_marginHorizontal="12dp"
        android:layout_marginTop="8dp"
        android:background="?attr/glyphSurfaceVariant"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:padding="2dp"
        android:visibility="gone"
        tools:visibility="visible">

        <TextView
            android:id="@+id/tvSourceSystem"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:gravity="center"
            android:text="🙂 Emoji"
            android:textSize="13sp"
            android:textStyle="bold"
            android:textColor="?attr/glyphTextPrimary"
            android:background="@drawable/bg_tab_selected" />

        <TextView
            android:id="@+id/tvSourceKlipy"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:gravity="center"
            android:text="✨ Klipy"
            android:textSize="13sp"
            android:textColor="?attr/glyphTextSecondary"
            android:background="?selectableItemBackground" />
    </LinearLayout>

    <!-- Search Bar -->
    <EditText
        android:id="@+id/etPickerSearch"
        android:layout_width="match_parent"
        android:layout_height="40dp"
        android:layout_marginHorizontal="12dp"
        android:layout_marginTop="6dp"
        android:layout_marginBottom="4dp"
        android:background="@drawable/bg_picker_search"
        android:drawableStart="@drawable/ic_search_small"
        android:drawablePadding="8dp"
        android:hint="Search KLIPY"
        android:imeOptions="actionSearch"
        android:inputType="text"
        android:maxLines="1"
        android:paddingHorizontal="12dp"
        android:textColor="?attr/glyphTextPrimary"
        android:textColorHint="?attr/glyphTextSecondary"
        android:textSize="14sp"
        android:focusable="true"
        android:focusableInTouchMode="true"
        tools:ignore="Autofill,LabelFor" />

    <!-- Content area (grid + loading + empty) -->
    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rvPickerGrid"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:clipToPadding="false"
            android:padding="4dp"
            android:scrollbars="vertical"
            android:nestedScrollingEnabled="false"
            android:overScrollMode="never"
            tools:listitem="@layout/item_picker_grid" />

        <ProgressBar
            android:id="@+id/pbPickerLoading"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:layout_gravity="center"
            android:visibility="gone"
            android:indeterminateTint="?attr/colorPrimary" />

        <TextView
            android:id="@+id/tvPickerEmpty"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:text="No results"
            android:textColor="?attr/glyphTextSecondary"
            android:textSize="14sp"
            android:visibility="gone" />
    </FrameLayout>

    <!-- Category Strip (Emoji Categories) -->
    <View
        android:id="@+id/viewCategoryDivider"
        android:layout_width="match_parent"
        android:layout_height="0.5dp"
        android:background="#1A000000"
        android:visibility="gone"
        tools:visibility="visible" />

    <RelativeLayout
        android:id="@+id/layoutCategoryContainer"
        android:layout_width="match_parent"
        android:layout_height="40dp"
        android:background="@color/picker_search_bg"
        android:visibility="gone"
        tools:visibility="visible">

        <HorizontalScrollView
            android:id="@+id/scrollCategoryStrip"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:layout_toStartOf="@+id/btnPickerDelete"
            android:scrollbars="none">

            <LinearLayout
                android:id="@+id/layoutCategoryStrip"
                android:layout_width="wrap_content"
                android:layout_height="match_parent"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingHorizontal="4dp" />
        </HorizontalScrollView>

        <ImageView
            android:id="@+id/btnPickerDelete"
            android:layout_width="56dp"
            android:layout_height="match_parent"
            android:layout_alignParentEnd="true"
            android:scaleType="centerInside"
            android:padding="8dp"
            android:src="@drawable/ic_backspace"
            android:background="@drawable/bg_picker_category_item"
            android:contentDescription="Delete"
            tools:tint="@android:color/white" />
    </RelativeLayout>

</LinearLayout>
