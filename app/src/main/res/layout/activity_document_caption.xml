<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="?attr/glyphToolbarBackground"
    android:fitsSystemWindows="true">

    <!-- Toolbar: back arrow + filename -->
    <LinearLayout
        android:id="@+id/toolbarContainer"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="4dp"
        android:paddingEnd="16dp"
        android:background="?attr/glyphToolbarBackground">

        <ImageButton
            android:id="@+id/btnBack"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:src="@drawable/ic_back_white"
            app:tint="?attr/glyphToolbarIcon"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="Back"
            android:scaleType="center" />

        <TextView
            android:id="@+id/tvTitle"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:textColor="?attr/glyphToolbarTitle"
            android:textSize="17sp"
            android:textStyle="bold"
            android:ellipsize="end"
            android:maxLines="1"
            android:layout_marginStart="4dp"
            android:text="Document" />

    </LinearLayout>

    <!-- Document preview area: fills remaining space -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:background="?attr/glyphToolbarBackground"
        android:fillViewport="true">

        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="16dp">

            <!-- PDF first-page render (visible only for PDFs) -->
            <ImageView
                android:id="@+id/ivDocPreview"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:adjustViewBounds="true"
                android:scaleType="fitCenter"
                android:elevation="4dp"
                android:background="?attr/glyphToolbarBackground"
                android:visibility="gone" />

            <!-- Non-PDF fallback: document icon + filename -->
            <LinearLayout
                android:id="@+id/llDocFallback"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center"
                android:paddingTop="64dp"
                android:paddingBottom="64dp"
                android:visibility="gone">

                <FrameLayout
                    android:layout_width="88dp"
                    android:layout_height="88dp">

                    <View
                        android:id="@+id/docIconBg"
                        android:layout_width="88dp"
                        android:layout_height="88dp"
                        android:background="@drawable/bg_attachment_icon_indigo" />

                    <ImageView
                        android:layout_width="48dp"
                        android:layout_height="48dp"
                        android:layout_gravity="center"
                        android:src="@drawable/ic_attachment_document"
                        android:tint="@android:color/white" />
                </FrameLayout>

                <TextView
                    android:id="@+id/tvDocFallbackName"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:gravity="center"
                    android:textColor="?attr/glyphTextPrimary"
                    android:layout_marginTop="20dp"
                    android:maxLines="3"
                    android:ellipsize="end" />

            </LinearLayout>

            <!-- Loading spinner (visible until preview renders) -->
            <ProgressBar
                android:id="@+id/progressLoading"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:layout_gravity="center"
                android:visibility="visible" />

        </FrameLayout>

    </ScrollView>

    <!-- Caption EditText -->
    <EditText
        android:id="@+id/etCaption"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="Add a caption…"
        android:minHeight="48dp"
        android:maxLines="4"
        android:paddingStart="20dp"
        android:paddingEnd="20dp"
        android:paddingTop="12dp"
        android:paddingBottom="12dp"
        android:layout_marginStart="12dp"
        android:layout_marginEnd="12dp"
        android:layout_marginTop="8dp"
        android:layout_marginBottom="4dp"
        android:textSize="15sp"
        android:textColor="?attr/glyphTextPrimary"
        android:textColorHint="?attr/glyphTextHint"
        android:background="@drawable/bg_caption_input"
        android:inputType="textMultiLine|textCapSentences"
        android:imeOptions="flagNoFullscreen" />

    <!-- Bottom bar: recipient + send FAB -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="64dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="16dp"
        android:paddingEnd="12dp"
        android:background="?attr/glyphToolbarBackground">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Sending to"
            android:textSize="13sp"
            android:textColor="?attr/glyphTextSecondary"
            android:layout_marginEnd="8dp" />

        <TextView
            android:id="@+id/tvRecipient"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_weight="0"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"
            android:paddingTop="6dp"
            android:paddingBottom="6dp"
            android:background="@drawable/bg_recipient_pill"
            android:textSize="13sp"
            android:textColor="?attr/glyphTextSecondary"
            android:ellipsize="end"
            android:maxLines="1" />

        <View
            android:layout_width="0dp"
            android:layout_height="1dp"
            android:layout_weight="1" />

        <com.google.android.material.floatingactionbutton.FloatingActionButton
            android:id="@+id/btnSend"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:src="@drawable/ic_send_white"
            app:tint="?attr/glyphIconPrimary"
            app:backgroundTint="?attr/glyphSendButton"
            app:fabSize="normal"
            app:maxImageSize="24dp"
            app:elevation="2dp" />

    </LinearLayout>

</LinearLayout>
