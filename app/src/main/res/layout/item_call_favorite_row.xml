<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="?attr/selectableItemBackground"
    android:minHeight="76dp"
    android:paddingStart="16dp"
    android:paddingTop="10dp"
    android:paddingEnd="12dp"
    android:paddingBottom="10dp">

    <FrameLayout
        android:id="@+id/avatarContainer"
        android:layout_width="56dp"
        android:layout_height="56dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <com.google.android.material.imageview.ShapeableImageView
            android:id="@+id/ivAvatar"
            android:layout_width="52dp"
            android:layout_height="52dp"
            android:layout_gravity="center"
            android:background="@drawable/bg_avatar_circle"
            android:contentDescription="@string/calls_contact_avatar"
            android:scaleType="centerCrop"
            app:shapeAppearanceOverlay="@style/CircularImageView" />

        <TextView
            android:id="@+id/tvAvatarInitial"
            android:layout_width="52dp"
            android:layout_height="52dp"
            android:layout_gravity="center"
            android:gravity="center"
            android:textColor="?attr/glyphTextPrimary"
            android:textSize="20sp"
            android:textStyle="bold"
            tools:text="N" />
    </FrameLayout>

    <TextView
        android:id="@+id/tvName"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="14dp"
        android:layout_marginEnd="10dp"
        android:ellipsize="end"
        android:maxLines="1"
        android:textColor="?attr/glyphTextPrimary"
        android:textSize="16sp"
        app:layout_constraintBottom_toBottomOf="@+id/avatarContainer"
        app:layout_constraintEnd_toStartOf="@+id/actionsContainer"
        app:layout_constraintStart_toEndOf="@+id/avatarContainer"
        app:layout_constraintTop_toTopOf="@+id/avatarContainer"
        tools:text="Nazia" />

    <LinearLayout
        android:id="@+id/actionsContainer"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        app:layout_constraintBottom_toBottomOf="@+id/avatarContainer"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="@+id/avatarContainer">

        <ImageButton
            android:id="@+id/btnVoiceCall"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="@string/calls_voice_call_favorite"
            android:src="@drawable/ic_phone"
            app:tint="?attr/glyphToolbarIcon" />

        <ImageButton
            android:id="@+id/btnVideoCall"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:layout_marginStart="8dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="@string/calls_video_call_favorite"
            android:src="@drawable/ic_video_call"
            app:tint="?attr/glyphToolbarIcon" />

        <ImageButton
            android:id="@+id/btnRemove"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:layout_marginStart="8dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="@string/calls_favorites_remove"
            android:src="@drawable/ic_close"
            android:visibility="gone"
            app:tint="?attr/glyphToolbarIcon" />

        <ImageView
            android:id="@+id/dragHandle"
            android:layout_width="20dp"
            android:layout_height="20dp"
            android:layout_marginStart="12dp"
            android:contentDescription="@string/calls_favorites_reorder"
            android:src="@drawable/ic_more_vert"
            android:visibility="gone"
            app:tint="?attr/glyphIconSecondary" />
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>