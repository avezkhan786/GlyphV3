<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="20dp"
    android:background="?attr/glyphSurface">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingBottom="8dp">

        <ImageView
            android:id="@+id/invite_icon"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:src="@drawable/ic_send"
            app:tint="?attr/glyphToolbarIcon"
            android:contentDescription="@null" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:paddingStart="12dp">

            <TextView
                android:id="@+id/invite_title"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textAppearance="?attr/textAppearanceHeadline6"
                android:textColor="?attr/glyphTextPrimary" />

            <TextView
                android:id="@+id/invite_subtitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textAppearance="?attr/textAppearanceBody2"
                android:textColor="?attr/glyphTextSecondary"
                android:paddingTop="2dp" />
        </LinearLayout>
    </LinearLayout>

    <EditText
        android:id="@+id/invite_message_preview"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/bg_invite_message_preview"
        android:padding="12dp"
        android:textColor="?attr/glyphTextPrimary"
        android:textAppearance="?attr/textAppearanceBody2"
        android:layout_marginBottom="12dp"
        android:lineSpacingExtra="2dp"
        android:gravity="top|start"
        android:minLines="3"
        android:inputType="textMultiLine"
        android:importantForAutofill="no" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="end">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_share"
            style="?attr/materialButtonOutlinedStyle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            app:icon="@drawable/ic_share"
            app:iconGravity="textStart"
            app:iconTint="?attr/glyphSendButton"
            android:text="@string/invite_share"
            android:layout_marginEnd="8dp"
            android:textColor="?attr/glyphSendButton"
            app:strokeColor="?attr/glyphSendButton"
            android:contentDescription="@string/invite_share" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_send_sms"
            style="?attr/materialButtonStyle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            app:icon="@drawable/ic_send"
            app:iconGravity="textStart"
            android:backgroundTint="?attr/glyphSendButton"
            app:iconTint="?attr/glyphOnPrimary"
            android:text="@string/invite_send_sms"
            android:textColor="?attr/glyphOnPrimary"
            android:contentDescription="@string/invite_send_sms" />
    </LinearLayout>

</LinearLayout>