<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@android:color/black">

    <!-- Image Preview -->
    <ImageView
        android:id="@+id/imagePreview"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:scaleType="fitCenter"
        android:visibility="gone" />

    <!-- Video Preview -->
    <androidx.media3.ui.PlayerView
        android:id="@+id/videoPreview"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        app:use_controller="false"
        app:resize_mode="fit"
        android:visibility="gone" />

    <!-- Video Note circular preview -->
    <FrameLayout
        android:id="@+id/videoNoteContainer"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:visibility="gone">

        <androidx.media3.ui.PlayerView
            android:id="@+id/videoNotePreview"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:layout_gravity="center"
            app:use_controller="false"
            app:resize_mode="zoom" />
            
        <!-- Video Note Progress Bar (matches recording screen) -->
        <com.google.android.material.progressindicator.CircularProgressIndicator
            android:id="@+id/videoNoteProgress"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            app:indicatorColor="@android:color/white"
            app:trackColor="#40FFFFFF"
            app:trackThickness="4dp"
            app:indicatorDirectionCircular="clockwise"
            android:max="60000"
            android:indeterminate="false" />
    </FrameLayout>

    <!-- Media Details Info -->
    <LinearLayout
        android:id="@+id/mediaInfoContainer"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="top|center_horizontal"
        android:layout_marginTop="84dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingHorizontal="12dp"
        android:paddingVertical="6dp"
        android:background="@drawable/bg_media_info_pill"
        android:visibility="gone">

        <TextView
            android:id="@+id/tvMediaDetails"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="@android:color/white"
            android:textSize="12sp"
            android:fontFamily="sans-serif-medium" />

    </LinearLayout>

    <!-- Play/Pause overlay for video -->
    <ImageView
        android:id="@+id/btnPlayPause"
        android:layout_width="64dp"
        android:layout_height="64dp"
        android:layout_gravity="center"
        android:background="@drawable/bg_camera_button"
        android:src="@drawable/ic_play_white"
        android:scaleType="centerInside"
        android:padding="16dp"
        android:visibility="gone"
        android:contentDescription="Play/Pause" />

    <!-- Top Bar -->
    <LinearLayout
        android:id="@+id/previewTopBar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingHorizontal="8dp"
        android:paddingTop="12dp"
        android:paddingBottom="12dp">

        <!-- Back/Retake -->
        <ImageButton
            android:id="@+id/btnRetake"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:background="@drawable/bg_camera_button"
            android:src="@drawable/ic_close"
            android:scaleType="centerInside"
            android:padding="12dp"
            app:tint="@android:color/white"
            android:contentDescription="Retake" />

        <View
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_weight="1" />

        <!-- Video duration label -->
        <TextView
            android:id="@+id/tvVideoDuration"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="@android:color/white"
            android:textSize="14sp"
            android:fontFamily="sans-serif-medium"
            android:background="@drawable/bg_media_info_pill"
            android:paddingHorizontal="12dp"
            android:paddingVertical="6dp"
            android:visibility="gone" />

    </LinearLayout>

    <!-- Bottom Send Bar -->
    <LinearLayout
        android:id="@+id/previewBottomBar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_gravity="bottom"
        android:paddingHorizontal="20dp"
        android:paddingVertical="12dp"
        android:background="#383838"
        android:elevation="8dp">

        <!-- Recipient Info (Left end) -->
        <TextView
            android:id="@+id/tvRecipient"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Sending to: "
            android:textColor="@android:color/white"
            android:textSize="14sp"
            android:fontFamily="sans-serif-medium"
            android:background="@drawable/bg_media_info_pill"
            android:paddingHorizontal="14dp"
            android:paddingVertical="8dp"
            android:alpha="0.9"
            android:singleLine="true"
            android:ellipsize="end" />

        <!-- Spacer to push button to the right end -->
        <View
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_weight="1" />

        <!-- Send Button (Full right end) -->
        <com.google.android.material.floatingactionbutton.FloatingActionButton
            android:id="@+id/btnSend"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:src="@drawable/ic_send_white"
            app:tint="@android:color/black"
            app:backgroundTint="@android:color/white"
            app:fabSize="normal"
            app:elevation="2dp"
            android:contentDescription="Send" />

        <!-- Legacy EditText hidden but kept for logic compatibility -->
        <EditText
            android:id="@+id/etCaption"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:visibility="gone" />

    </LinearLayout>

</FrameLayout>
