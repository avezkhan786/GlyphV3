<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="52dp">

    <!-- Background Card -->
    <androidx.cardview.widget.CardView
        android:id="@+id/cardQuality"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        app:cardBackgroundColor="@color/glyph_card_bg"
        app:cardCornerRadius="10dp"
        app:cardElevation="0dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="?attr/selectableItemBackground"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingHorizontal="12dp">

            <!-- Radio Indicator (Custom Circle) -->
            <FrameLayout
                android:layout_width="20dp"
                android:layout_height="20dp">

                <View
                    android:id="@+id/radioOuter"
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:background="@drawable/bg_radio_outer" />

                <View
                    android:id="@+id/radioInner"
                    android:layout_width="10dp"
                    android:layout_height="10dp"
                    android:layout_gravity="center"
                    android:background="@drawable/bg_radio_inner"
                    android:visibility="gone" />
            </FrameLayout>

            <!-- Quality Info -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="10dp"
                android:layout_weight="1"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <TextView
                    android:id="@+id/tvQualityName"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="@color/glyph_text_primary"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    tools:text="Medium" />

                <TextView
                    android:id="@+id/tvRecommended"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="6dp"
                    android:background="@drawable/bg_pill_recommended"
                    android:paddingHorizontal="5dp"
                    android:paddingVertical="1dp"
                    android:text="★"
                    android:textColor="@color/glyph_primary"
                    android:textSize="9sp"
                    android:visibility="gone"
                    tools:visibility="visible" />

                <TextView
                    android:id="@+id/tvQualityDescription"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="8dp"
                    android:ellipsize="end"
                    android:maxLines="1"
                    android:textColor="@color/glyph_text_hint"
                    android:textSize="11sp"
                    tools:text="Balanced quality" />
            </LinearLayout>

            <!-- Size Info -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:gravity="end|center_vertical"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/tvReduction"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="@color/glyph_online_green"
                    android:textSize="11sp"
                    android:visibility="gone"
                    tools:text="-65%"
                    tools:visibility="visible" />

                <TextView
                    android:id="@+id/tvEstimatedSize"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="6dp"
                    android:textColor="@color/glyph_text_primary"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    tools:text="12.4 MB" />
            </LinearLayout>
        </LinearLayout>
    </androidx.cardview.widget.CardView>

    <!-- Selected Border Overlay (exact same size as card) -->
    <View
        android:id="@+id/selectedBorder"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@drawable/bg_selected_quality_border"
        android:visibility="gone" />

</FrameLayout>
