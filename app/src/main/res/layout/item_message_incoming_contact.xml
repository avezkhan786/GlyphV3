<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:clipChildren="false"
    android:clipToPadding="false"
    android:paddingStart="8dp"
    android:paddingEnd="8dp"
    android:paddingTop="0dp"
    android:paddingBottom="0dp">

    <!-- Contact Card Bubble (incoming - left aligned) -->
    <FrameLayout
        android:id="@+id/cardMessage"
        android:layout_width="260dp"
        android:layout_height="wrap_content"
        android:background="@drawable/bg_message_incoming"
        android:clipToOutline="true"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <include layout="@layout/layout_group_sender_name" />

            <include layout="@layout/layout_forwarded_label" />

            <!-- Top section: avatar + name + phone -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingStart="10dp"
                android:paddingEnd="10dp"
                android:paddingTop="8dp"
                android:paddingBottom="8dp">

                <!-- Circular Avatar -->
                <FrameLayout
                    android:layout_width="44dp"
                    android:layout_height="44dp"
                    android:layout_marginEnd="8dp">

                    <!-- Background circle (shown when no image avatar) -->
                    <View
                        android:id="@+id/viewAvatarBg"
                        android:layout_width="44dp"
                        android:layout_height="44dp"
                        android:background="@drawable/bg_contact_avatar_default" />

                    <!-- Initials text (shown when unregistered or image not loaded) -->
                    <TextView
                        android:id="@+id/tvAvatarInitials"
                        android:layout_width="44dp"
                        android:layout_height="44dp"
                        android:gravity="center"
                        android:textColor="#FFFFFF"
                        android:textSize="18sp"
                        android:textStyle="bold"
                        tools:text="AA" />

                    <!-- Actual profile image (shown when registered and has avatar) -->
                    <com.google.android.material.imageview.ShapeableImageView
                        android:id="@+id/ivContactAvatar"
                        android:layout_width="44dp"
                        android:layout_height="44dp"
                        android:scaleType="centerCrop"
                        android:visibility="gone"
                        app:shapeAppearanceOverlay="@style/CircularImageView" />

                </FrameLayout>

                <!-- Name + Phone vertical -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/tvContactName"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:textColor="?attr/glyphBubbleOtherText"
                        android:textSize="15sp"
                        android:textStyle="bold"
                        android:maxLines="2"
                        android:ellipsize="end"
                        tools:text="Aditya Agent" />

                    <TextView
                        android:id="@+id/tvContactPhone"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:textColor="?attr/glyphBubbleOtherText"
                        android:alpha="0.85"
                        android:textSize="13sp"
                        android:layout_marginTop="2dp"
                        android:maxLines="1"
                        android:ellipsize="end"
                        tools:text="+91 99161 04884" />

                    <!-- "On Glyph" badge (shown when registered) -->
                    <LinearLayout
                        android:id="@+id/llOnGlyphBadge"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginTop="4dp"
                        android:visibility="gone"
                        tools:visibility="visible">

                        <ImageView
                            android:layout_width="12dp"
                            android:layout_height="12dp"
                            android:src="@drawable/ic_check_circle"
                            app:tint="?attr/glyphSuccess"
                            android:layout_marginEnd="4dp" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="on Glyph"
                            android:textColor="?attr/glyphSuccess"
                            android:textSize="11sp"
                            android:textStyle="bold" />

                    </LinearLayout>

                </LinearLayout>

            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="#08000000">

                <!-- Action buttons row -->
                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="?attr/glyphBubbleOtherText"
                    android:alpha="0.2" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center"
                    android:paddingTop="4dp"
                    android:paddingBottom="0dp">

                    <!-- Message: shown when contact IS on Glyph -->
                    <TextView
                        android:id="@+id/btnMessage"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:paddingStart="12dp"
                        android:paddingEnd="12dp"
                        android:paddingTop="3dp"
                        android:paddingBottom="3dp"
                        android:text="Message"
                        android:textColor="?attr/glyphToolbarIcon"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:fontFamily="sans-serif-black"
                        android:clickable="true"
                        android:focusable="true"
                        android:background="@null"
                        android:visibility="gone"
                        tools:visibility="visible" />

                    <!-- Invite: shown when contact is NOT on Glyph -->
                    <TextView
                        android:id="@+id/btnInvite"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:paddingStart="12dp"
                        android:paddingEnd="12dp"
                        android:paddingTop="3dp"
                        android:paddingBottom="3dp"
                        android:text="Invite to Glyph"
                        android:textColor="?attr/glyphToolbarIcon"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:fontFamily="sans-serif-black"
                        android:clickable="true"
                        android:focusable="true"
                        android:background="@null"
                        android:visibility="gone"
                        tools:visibility="visible" />

                </LinearLayout>

                <!-- Bottom bar: timestamp at the right side -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="end|center_vertical"
                    android:paddingTop="0dp"
                    android:paddingEnd="8dp"
                    android:paddingBottom="4dp">

                    <TextView
                        android:id="@+id/tvTimestamp"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textColor="?attr/glyphBubbleOtherText"
                        android:alpha="0.85"
                        android:textSize="12sp"
                        tools:text="10:30 am" />
                </LinearLayout>

            </LinearLayout>

        </LinearLayout>

    </FrameLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
