<?xml version="1.0" encoding="utf-8"?>
<!-- Chat-close exit: slides the finishing chat out toward the right (where it
     entered from) and fades it so the underlying chat list is revealed without a
     hard pop at animation end. The chat list has no enter anim (it is already
     visible beneath), so only this exit tween runs on back. -->
<set xmlns:android="http://schemas.android.com/apk/res/android"
    android:interpolator="@android:interpolator/decelerate_quad">
    <translate
        android:fromXDelta="0%"
        android:toXDelta="15%"
        android:duration="180" />
    <alpha
        android:fromAlpha="1.0"
        android:toAlpha="0.0"
        android:duration="180" />
</set>
