        <item name="glyphFabBackground">@color/pastel_mint_cloud</item>
        <item name="glyphFabIcon">@color/pastel_deep_indigo</item>
        <item name="glyphScrollFabBackground">@color/pastel_sky_blue</item>
        <item name="glyphScrollFabIcon">@color/pastel_deep_indigo</item>
        <item name="glyphScrollFabBorder">@color/pastel_input_border</item>
        
        <!-- Selection Colors -->
        <item name="glyphSelectionBackground">#30CFE9F3</item>
        <item name="glyphSelectionHighlight">#18DFF2EA</item>
        
        <!-- FAB styling -->
        <item name="floatingActionButtonStyle">@style/GlyphFabStyle.PastelSky</item>
    </style>
    
    <!-- Default theme (points to Light) -->
    <style name="Theme.GlyphV3" parent="Theme.GlyphV3.Light" />

    <!--
        Branded splash: applied before super.onCreate() on the first cold-start frame.
        Uses a white window background so the launcher icon transition is smooth.
        ThemeManager replaces this with the real app theme immediately after.
    -->
    <style name="Theme.GlyphV3.SplashBranded" parent="Theme.AppCompat.NoActionBar">
        <item name="android:windowBackground">@color/white</item>
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:windowLightStatusBar">true</item>
        <item name="android:navigationBarColor">@color/white</item>
        <item name="android:windowLightNavigationBar">true</item>
    </style>

    <style name="Theme.GlyphV3.TransparentLiveAudio" parent="Theme.AppCompat.NoActionBar">
        <item name="android:windowBackground">@android:color/transparent</item>
        <item name="android:windowIsTranslucent">true</item>
        <item name="android:windowNoTitle">true</item>
        <item name="android:windowIsFloating">false</item>
        <item name="android:windowDisablePreview">true</item>
        <item name="android:backgroundDimEnabled">false</item>
        <item name="android:windowAnimationStyle">@null</item>
    </style>

    <!-- AvatarPreview: transparent window so we can draw our own animated black scrim -->
    <style name="Theme.GlyphV3.AvatarPreview" parent="Theme.GlyphV3">
        <item name="android:windowBackground">@android:color/transparent</item>
        <item name="android:windowIsTranslucent">true</item>
        <item name="android:windowAnimationStyle">@null</item>
        <item name="android:windowContentTransitions">false</item>
        <item name="android:backgroundDimEnabled">false</item>
    </style>
    
    <!-- ========== FAB STYLES ========== -->
    <style name="GlyphFabStyle.Light" parent="Widget.Material3.FloatingActionButton.Primary">
        <item name="backgroundTint">@drawable/bg_fab_gradient</item>
        <item name="tint">@color/white</item>
        <item name="elevation">8dp</item>
    </style>
    
    <style name="GlyphFabStyle.Dark" parent="Widget.Material3.FloatingActionButton.Primary">
        <item name="backgroundTint">@color/dark_primary</item>
        <item name="tint">@color/white</item>
        <item name="elevation">8dp</item>
    </style>
    
    <style name="GlyphFabStyle.PastelSky" parent="Widget.Material3.FloatingActionButton.Primary">
        <item name="backgroundTint">@color/pastel_mint_cloud</item>
        <item name="tint">@color/pastel_send_button_icon</item>
        <item name="elevation">2dp</item>
    </style>
    
    <!-- ========== TEXT STYLES ========== -->
    <style name="TextAppearance.Glyph.Headline" parent="TextAppearance.Material3.HeadlineMedium">
        <item name="android:textSize">26sp</item>
        <item name="android:textStyle">bold</item>
        <item name="fontFamily">sans-serif-medium</item>
    </style>
    
    <style name="TextAppearance.Glyph.Title" parent="TextAppearance.Material3.TitleLarge">
        <item name="android:textSize">18sp</item>
        <item name="android:textStyle">bold</item>
        <item name="fontFamily">sans-serif-medium</item>
    </style>
    
    <style name="TextAppearance.Glyph.Body" parent="TextAppearance.Material3.BodyLarge">
        <item name="android:textSize">16sp</item>
        <item name="fontFamily">sans-serif</item>
    </style>
    
    <style name="TextAppearance.Glyph.Caption" parent="TextAppearance.Material3.BodySmall">
        <item name="android:textSize">14sp</item>
        <item name="fontFamily">sans-serif</item>
    </style>
    
    <!-- Glyph Toolbar Title Style - WhatsApp style (compact, SemiBold) -->
    <style name="GlyphToolbarTitle" parent="TextAppearance.Material3.TitleLarge">
        <item name="android:textSize">23sp</item>
        <item name="android:textStyle">normal</item>
        <item name="android:textColor">?attr/glyphToolbarTitle</item>
        <item name="android:fontFamily">sans-serif-medium</item>
        <item name="android:textFontWeight">600</item>
    </style>

    <!-- Glyph Main Toolbar Title for chat list (white, larger, bold) -->
    <style name="GlyphMainToolbarTitle" parent="TextAppearance.Material3.TitleLarge">
        <item name="android:textSize">24sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textColor">@color/white</item>
        <item name="android:fontFamily">sans-serif-medium</item>
        <item name="android:textFontWeight">700</item>
    </style>
    
    <!-- Bottom Sheet Dialog Theme -->
    <style name="BottomSheetDialogTheme" parent="Theme.Material3.DayNight.BottomSheetDialog">
        <item name="bottomSheetStyle">@style/BottomSheetStyle</item>
        <item name="android:windowIsFloating">false</item>
        <item name="android:windowSoftInputMode">adjustResize</item>
    </style>
    
    <style name="BottomSheetStyle" parent="Widget.Material3.BottomSheet.Modal">
        <item name="android:background">@android:color/transparent</item>
        <item name="backgroundTint">@android:color/transparent</item>
    </style>
    
    <!-- ========== POPUP MENU THEMES ========== -->
    <style name="PopupTheme" parent="ThemeOverlay.Material3">
        <item name="android:textColor">?attr/glyphTextPrimary</item>
        <item name="android:colorBackground">?attr/colorSurface</item>
    </style>
    
    <style name="ToolbarTheme" parent="ThemeOverlay.Material3.Dark.ActionBar">
        <item name="colorControlNormal">?attr/glyphToolbarIcon</item>
    </style>
    
    <!-- ========== MATERIAL CARD STYLES ========== -->
    <style name="GlyphCard" parent="Widget.Material3.CardView.Elevated">
        <item name="cardBackgroundColor">?attr/glyphCardBackground</item>
        <item name="cardCornerRadius">12dp</item>
        <item name="cardElevation">2dp</item>
    </style>
    
    <style name="GlyphCard.Chat" parent="GlyphCard">
        <item name="cardCornerRadius">16dp</item>
    </style>
    
    <!-- ========== BUTTON STYLES ========== -->
    <style name="GlyphButton.Primary" parent="Widget.Material3.Button">
        <item name="backgroundTint">?attr/glyphPrimary</item>
        <item name="android:textColor">?attr/glyphOnPrimary</item>
    </style>
    
    <style name="GlyphButton.Secondary" parent="Widget.Material3.Button.OutlinedButton">
        <item name="strokeColor">?attr/glyphPrimary</item>
        <item name="android:textColor">?attr/glyphPrimary</item>
    </style>
    
</resources>