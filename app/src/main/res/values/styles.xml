<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- Circular Image View Style for ShapeableImageView -->
    <style name="CircleImageView" parent="">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">50%</item>
    </style>
    
    <!-- Alias for CircularImageView (used in other layouts) -->
    <style name="CircularImageView" parent="">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">50%</item>
    </style>

    <style name="RoundedCornerImage" parent="">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">8dp</item>
    </style>

    <style name="RoundedCornerImageView" parent="">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">4dp</item>
    </style>

    <style name="RoundedCornerPreviewThumb" parent="">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSizeTopLeft">16dp</item>
        <item name="cornerSizeBottomLeft">16dp</item>
        <item name="cornerSizeTopRight">0dp</item>
        <item name="cornerSizeBottomRight">0dp</item>
    </style>

    <style name="RoundedCornerPreviewThumbTop" parent="">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSizeTopLeft">16dp</item>
        <item name="cornerSizeTopRight">16dp</item>
        <item name="cornerSizeBottomLeft">0dp</item>
        <item name="cornerSizeBottomRight">0dp</item>
    </style>
    
    <!-- Profile Preview Dialog Theme -->
    <style name="ProfilePreviewDialogTheme" parent="Theme.Material3.DayNight.Dialog">
        <item name="android:windowIsFloating">false</item>
        <item name="android:windowBackground">@android:color/transparent</item>
        <item name="android:windowNoTitle">true</item>
        <item name="android:windowContentOverlay">@null</item>
        <item name="android:backgroundDimEnabled">false</item>
        <item name="android:statusBarColor">@android:color/transparent</item>
    </style>
    
    <!-- Transparent Bottom Sheet Dialog Theme -->
    <style name="TransparentBottomSheetDialog" parent="ThemeOverlay.Material3.BottomSheetDialog">
        <item name="android:windowIsFloating">false</item>
        <item name="android:windowBackground">@android:color/transparent</item>
        <item name="android:windowNoTitle">true</item>
        <item name="bottomSheetStyle">@style/TransparentBottomSheet</item>
        <item name="android:backgroundDimEnabled">false</item>
    </style>
    
    <style name="TransparentBottomSheet" parent="Widget.Material3.BottomSheet.Modal">
        <item name="android:background">@android:color/transparent</item>
    </style>
    
    <!-- ========== WhatsApp-style Bottom Navigation Styles ========== -->
    <style name="GlyphBottomNavTextActive" parent="@style/GlyphBottomNavTextInactive">
        <!-- Inherits all properties from inactive to ensure no bold is applied -->
    </style>
    
    <style name="GlyphBottomNavTextInactive">
        <item name="android:textSize">15sp</item>
        <item name="android:lineHeight">15sp</item>
        <item name="android:fontFamily">sans-serif</item>
        <item name="android:textFontWeight">500</item>
        <item name="android:includeFontPadding">false</item>
        <item name="android:paddingTop">0dp</item>
        <item name="android:paddingBottom">0dp</item>
        <item name="android:layout_marginTop">0dp</item>
        <item name="android:layout_marginBottom">0dp</item>
    </style>
    
    <!-- Bottom Navigation Active Indicator (pill shape) -->
    <style name="GlyphBottomNavActiveIndicator" parent="Widget.Material3.BottomNavigationView.ActiveIndicator">
        <!-- Subtle, semi-transparent highlight that does not cover the icon -->
        <item name="android:color">@color/bottom_nav_active_indicator</item>
        <item name="android:height">32dp</item>
        <item name="android:width">60dp</item>
    </style>
    
    <!-- ========== Search Bar Style ========== -->
    <style name="GlyphSearchBarStyle" parent="Widget.Material3.TextInputLayout.OutlinedBox">
        <item name="boxCornerRadiusTopStart">24dp</item>
        <item name="boxCornerRadiusTopEnd">24dp</item>
        <item name="boxCornerRadiusBottomStart">24dp</item>
        <item name="boxCornerRadiusBottomEnd">24dp</item>
        <item name="boxStrokeWidth">0dp</item>
        <item name="boxStrokeWidthFocused">0dp</item>
        <item name="hintEnabled">false</item>
    </style>

    <style name="GlyphConfirmationDialog" parent="ThemeOverlay.Material3.MaterialAlertDialog">
        <item name="backgroundTint">@android:color/transparent</item>
        <item name="android:windowMinWidthMajor">92%</item>
        <item name="android:windowMinWidthMinor">92%</item>
        <item name="shapeAppearanceMediumComponent">@style/GlyphConfirmationDialog.Shape</item>
    </style>

    <style name="GlyphConfirmationDialog.Shape" parent="ShapeAppearance.Material3.LargeComponent">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">28dp</item>
    </style>

    <style name="GlyphDialogWindowAnimation">
        <item name="android:windowEnterAnimation">@anim/glyph_dialog_enter</item>
        <item name="android:windowExitAnimation">@anim/glyph_dialog_exit</item>
    </style>

    <style name="GlyphDialogActionButton.Base" parent="Widget.Material3.Button">
        <item name="android:minHeight">48dp</item>
        <item name="cornerRadius">18dp</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:textStyle">bold</item>
        <item name="android:insetTop">0dp</item>
        <item name="android:insetBottom">0dp</item>
    </style>

    <style name="GlyphDialogActionButton.Tonal" parent="GlyphDialogActionButton.Base">
        <item name="backgroundTint">?attr/colorSurfaceVariant</item>
        <item name="android:textColor">?attr/colorOnSurface</item>
        <item name="iconTint">?attr/colorOnSurface</item>
        <item name="strokeWidth">0dp</item>
    </style>

    <style name="GlyphDialogActionButton.Filled" parent="GlyphDialogActionButton.Base">
        <item name="backgroundTint">?attr/colorPrimary</item>
        <item name="android:textColor">?attr/colorOnPrimary</item>
        <item name="iconTint">?attr/colorOnPrimary</item>
        <item name="strokeWidth">0dp</item>
        <item name="elevation">0dp</item>
    </style>
</resources>
